  "world_info": {
    "entries": {
      "WORLD_INFO_ACTION_DESC": "You have a series of executable actions. Pay attention to the effects, restrictions, regions, and time of actions.",
      "WORLD_INFO_ACTION_NAME": "Action",
      "WORLD_INFO_ACTION_TITLE": "Action",
      "WORLD_INFO_AUCTION_DESC": "Every uncertain period of time, there will be an auction organized by a mysterious person, perhaps selling good goods.",
      "WORLD_INFO_AUCTION_NAME": "Auction",
      "WORLD_INFO_AUCTION_TITLE": "Auction",
      "WORLD_INFO_BATTLE_DESC": "Survival of the fittest; realm suppression is huge, high-realm cultivators have an absolute advantage over low-realm ones. If the opponent dies, the winner can plunder the loser's belongings.",
      "WORLD_INFO_BATTLE_NAME": "Battle",
      "WORLD_INFO_BATTLE_TITLE": "Battle",
      "WORLD_INFO_CULTIVATION_DESC": "Cultivation increases experience until reaching the bottleneck before breakthrough. Breakthrough is a probability event; upon success, one enters the next realm.",
      "WORLD_INFO_CULTIVATION_NAME": "Cultivation",
      "WORLD_INFO_CULTIVATION_TITLE": "Cultivation",
      "WORLD_INFO_DEATH_DESC": "HP dropping below 0 also causes death.",
      "WORLD_INFO_DEATH_NAME": "Death",
      "WORLD_INFO_DEATH_TITLE": "Death",
      "WORLD_INFO_EQUIPMENT_AND_ELIXIR_DESC": "Through weapons, auxiliary equipment, elixirs, etc., you can gain extra attribute bonuses and small or large buffs. Owning good equipment or taking good elixirs can bring great benefits.",
      "WORLD_INFO_EQUIPMENT_AND_ELIXIR_NAME": "Equipment & Elixir",
      "WORLD_INFO_EQUIPMENT_AND_ELIXIR_TITLE": "Equipment & Elixir",
      "WORLD_INFO_INTRO_DESC": "This is a cultivation world where many cultivators compete and conflicts rage on all sides.",
      "WORLD_INFO_INTRO_NAME": "Introduction",
      "WORLD_INFO_INTRO_TITLE": "Introduction",
      "WORLD_INFO_LIFESPAN_DESC": "If a character's current age reaches their maximum lifespan, they die immediately. Breaking through to a new realm can increase maximum lifespan, while failure may also reduce it.",
      "WORLD_INFO_LIFESPAN_NAME": "Lifespan",
      "WORLD_INFO_LIFESPAN_TITLE": "Lifespan",
      "WORLD_INFO_ORTHODOXY_DESC": "Different orthodoxies have different cultivation methods. Taoists respire, Martial Artists practice Body Tempering, Buddhists meditate, and Confucians educate the people.",
      "WORLD_INFO_ORTHODOXY_NAME": "Orthodoxy",
      "WORLD_INFO_ORTHODOXY_TITLE": "Orthodoxy",
      "WORLD_INFO_REALM_DESC": "Cultivation realms from weak to strong: Qi Refinement, Foundation Establishment, Core Formation, Nascent Soul. Each realm is divided into Early, Middle, and Late stages. The gap between realms is huge.",
      "WORLD_INFO_REALM_NAME": "Realm",
      "WORLD_INFO_REALM_TITLE": "Realm",
      "WORLD_INFO_REGION_DESC": "Different regions have different effects; doing the right thing in the right region yields twice the result with half the effort.",
      "WORLD_INFO_REGION_NAME": "Region",
      "WORLD_INFO_REGION_TITLE": "Region",
      "WORLD_INFO_ROOT_DESC": "Spirit roots are composed of five elements (Metal, Wood, Water, Fire, Earth), divided into Single, Dual, and Heavenly Spirit Roots. Five elements interaction: Metal overcomes Wood, Wood overcomes Earth, Earth overcomes Water, Water overcomes Fire, Fire overcomes Metal. Heavenly Spirit Root contains all five elements and has an extra bonus during breakthrough. Cultivation efficiency is highest in regions matching one's own spirit root attribute.",
      "WORLD_INFO_ROOT_NAME": "Spirit Root",
      "WORLD_INFO_ROOT_TITLE": "Spirit Root",
      "WORLD_INFO_SECRET_REALM_DESC": "Secret realms open every few years. Entering a secret realm may encounter danger, but may also obtain high-level artifacts and techniques.",
      "WORLD_INFO_SECRET_REALM_NAME": "Secret Realm",
      "WORLD_INFO_SECRET_REALM_TITLE": "Secret Realm",
      "WORLD_INFO_SECT_DESC": "A shelter for cultivators. Joining a sect allows learning unique techniques and gaining protection from fellow disciples; rogue cultivators are free but lack resources.",
      "WORLD_INFO_SECT_NAME": "Sect",
      "WORLD_INFO_SECT_TITLE": "Sect",
      "WORLD_INFO_SHOPPING_DESC": "In city regions, you can buy Qi Refinement level elixirs and weapons. Buying elixirs will immediately consume them to strengthen yourself. Buying weapons can help you switch your weapon type to a handy one.",
      "WORLD_INFO_SHOPPING_NAME": "Shopping",
      "WORLD_INFO_SHOPPING_TITLE": "Shopping",
      "WORLD_INFO_SPIRIT_STONE_DESC": "The common currency of the cultivation world. Can be used to buy artifacts and elixirs, obtained through gathering, trading, or plundering.",
      "WORLD_INFO_SPIRIT_STONE_NAME": "Spirit Stone",
      "WORLD_INFO_SPIRIT_STONE_TITLE": "Spirit Stone",
      "WORLD_INFO_WORLD_QI_DESC": "The world undergoes celestial changes (such as Qi Tides) every few years, affecting character abilities.",
      "WORLD_INFO_WORLD_QI_NAME": "World Qi",
      "WORLD_INFO_WORLD_QI_TITLE": "World Qi",
      "WORLD_INFO_RANKING_DESC": "The cultivation world features the Heaven, Earth, and Human Rankings, as well as the Sect Ranking. The Heaven Ranking records Nascent Soul experts, the Earth Ranking records Core Formation experts, and the Human Ranking records Foundation Establishment experts. The Sect Ranking ranks sects by their total power.",
      "WORLD_INFO_RANKING_NAME": "Ranking",
      "WORLD_INFO_RANKING_TITLE": "Ranking",
      "WORLD_INFO_DYNASTY_DESC": "Mortal dynasties rule the realm, maintaining worldly order and borders. Emperors live no longer than ordinary mortals, and when one dies, a new emperor succeeds to the throne.",
      "WORLD_INFO_DYNASTY_NAME": "Dynasty",
      "WORLD_INFO_DYNASTY_TITLE": "Dynasty",
      "WORLD_INFO_OFFICIAL_DESC": "Cultivators may govern for the imperial court, building court reputation and receiving salary. With enough reputation they can be promoted; the higher the office, the greater the salary and luck. If they neglect governance for too long, their reputation will gradually decline.",
      "WORLD_INFO_OFFICIAL_NAME": "Official Rank",
      "WORLD_INFO_OFFICIAL_TITLE": "Official Rank"
    }
  },
