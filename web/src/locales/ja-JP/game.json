    "entries": {
      "WORLD_INFO_ACTION_DESC": "あなたはさまざまな行動を実行できる。行動ごとの効果、制限条件、対応区域、所要時間に注意すること。",
      "WORLD_INFO_ACTION_NAME": "行動",
      "WORLD_INFO_ACTION_TITLE": "行動",
      "WORLD_INFO_AUCTION_DESC": "一定ではない周期で、謎の人物が主催する競売会が開かれる。思わぬ掘り出し物が出ることもある。",
      "WORLD_INFO_AUCTION_NAME": "競売会",
      "WORLD_INFO_AUCTION_TITLE": "競売会",
      "WORLD_INFO_BATTLE_DESC": "弱肉強食の世界であり、境界差による抑圧は極めて大きい。高境界の修士は低境界の修士に対して絶対的優位を持つ。相手を殺せば、その財物を奪うこともできる。",
      "WORLD_INFO_BATTLE_NAME": "戦闘",
      "WORLD_INFO_BATTLE_TITLE": "戦闘",
      "WORLD_INFO_CULTIVATION_DESC": "修行によって経験を積み、突破前の瓶頸へ至ることができる。突破は確率イベントであり、成功すれば次の境界へ進む。",
      "WORLD_INFO_CULTIVATION_NAME": "修行",
      "WORLD_INFO_CULTIVATION_TITLE": "修行",
      "WORLD_INFO_DEATH_DESC": "HP が 0 を下回っても死亡する。",
      "WORLD_INFO_DEATH_NAME": "死亡",
      "WORLD_INFO_DEATH_TITLE": "死亡",
      "WORLD_INFO_EQUIPMENT_AND_ELIXIR_DESC": "武器、補助装備、丹薬などを通じて追加属性や大小さまざまな強化を得られる。優れた装備や丹薬は大きな助けとなる。",
      "WORLD_INFO_EQUIPMENT_AND_ELIXIR_NAME": "装備と丹薬",
      "WORLD_INFO_EQUIPMENT_AND_ELIXIR_TITLE": "装備と丹薬",
      "WORLD_INFO_INTRO_DESC": "これは多くの修士が修行を競い、各地で争いが絶えない仙道世界である。",
      "WORLD_INFO_INTRO_NAME": "導入",
      "WORLD_INFO_INTRO_TITLE": "導入",
      "WORLD_INFO_LIFESPAN_DESC": "現在年齢が最大寿元に達すると即座に死亡する。境界突破は最大寿元を伸ばすことがあり、突破失敗で寿元を損なう場合もある。",
      "WORLD_INFO_LIFESPAN_NAME": "寿元",
      "WORLD_INFO_LIFESPAN_TITLE": "寿元",
      "WORLD_INFO_ORTHODOXY_DESC": "道・仏・儒などの道統によって修行法は異なる。道門は吐納し、武道は鍛体し、仏門は坐禅し、儒門は教化を行う。",
      "WORLD_INFO_ORTHODOXY_NAME": "道統",
      "WORLD_INFO_ORTHODOXY_TITLE": "道統",
      "WORLD_INFO_REALM_DESC": "修行境界は弱い方から順に、練気・築基・金丹・元嬰。各境界は前期・中期・後期に分かれ、境界差は非常に大きい。",
      "WORLD_INFO_REALM_NAME": "境界",
      "WORLD_INFO_REALM_TITLE": "境界",
      "WORLD_INFO_REGION_DESC": "区域ごとに異なる効果があり、適切な場所で適切な行動を取れば効率が大きく上がる。",
      "WORLD_INFO_REGION_NAME": "区域",
      "WORLD_INFO_REGION_TITLE": "区域",
      "WORLD_INFO_ROOT_DESC": "霊根は金・木・水・火・土の五行から成り、単霊根・双霊根・天霊根などに分かれる。五行には相克があり、天霊根は突破時に追加補正を得る。自らの属性に合う区域では修行効率が最も高い。",
      "WORLD_INFO_ROOT_NAME": "霊根",
      "WORLD_INFO_ROOT_TITLE": "霊根",
      "WORLD_INFO_SECRET_REALM_DESC": "数年ごとに秘境が開かれる。入れば危険に遭うこともあるが、高階の法宝や功法を得られる可能性もある。",
      "WORLD_INFO_SECRET_REALM_NAME": "秘境",
      "WORLD_INFO_SECRET_REALM_TITLE": "秘境",
      "WORLD_INFO_SECT_DESC": "宗門は修士の庇護所である。加入すれば独門の功法を学び、同門の庇護を受けられる。一方、散修は自由だが資源に乏しい。",
      "WORLD_INFO_SECT_NAME": "宗門",
      "WORLD_INFO_SECT_TITLE": "宗門",
      "WORLD_INFO_SHOPPING_DESC": "都市区域では練気級の丹薬や武器を購入できる。丹薬は購入後すぐ服用され、武器は自分に合う武器種へ持ち替える助けとなる。",
      "WORLD_INFO_SHOPPING_NAME": "購買",
      "WORLD_INFO_SHOPPING_TITLE": "購買",
      "WORLD_INFO_SPIRIT_STONE_DESC": "仙道界で広く通用する貨幣。法宝や丹薬の購入に使え、採集、交易、略奪などで手に入る。",
      "WORLD_INFO_SPIRIT_STONE_NAME": "霊石",
      "WORLD_INFO_SPIRIT_STONE_TITLE": "霊石",
      "WORLD_INFO_WORLD_QI_DESC": "世界では数年ごとに天象変動が起こり、たとえば霊気潮汐のような現象が人物の能力へ影響を与える。",
      "WORLD_INFO_WORLD_QI_NAME": "天地霊気",
      "WORLD_INFO_WORLD_QI_TITLE": "天地霊気",
      "WORLD_INFO_RANKING_DESC": "仙道界には天・地・人の榜と宗門ランキングがある。天榜には元嬰期の強者、地榜には結丹期の強者、人榜には築基期の強者が記され、宗門ランキングは宗門の総合実力で順位付けされる。",
      "WORLD_INFO_RANKING_NAME": "榜",
      "WORLD_INFO_RANKING_TITLE": "榜",
      "WORLD_INFO_DYNASTY_DESC": "人間の王朝が天下を治め、俗世の秩序と疆域を保っている。皇帝の寿命も常人と大差なく、崩御すれば新たな帝が即位する。",
      "WORLD_INFO_DYNASTY_NAME": "王朝",
      "WORLD_INFO_DYNASTY_TITLE": "王朝",
      "WORLD_INFO_OFFICIAL_DESC": "修士は朝廷のために政務を執り、声望を積み上げて俸禄を受け取れる。声望が十分なら昇進でき、官位が高いほど俸禄と気運も増す。長く政務を怠れば声望は徐々に下がる。",
      "WORLD_INFO_OFFICIAL_NAME": "官位",
      "WORLD_INFO_OFFICIAL_TITLE": "官位"
    }
  },
