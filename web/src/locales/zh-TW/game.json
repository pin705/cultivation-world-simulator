      "WORLD_INFO_AUCTION_NAME": "拍賣會",
      "WORLD_INFO_AUCTION_TITLE": "拍卖会",
      "WORLD_INFO_BATTLE_DESC": "弱肉強食，境界壓制極大，高境界者對低境界者有絕對優勢。若對方死亡，勝者可掠奪敗者財物。",
      "WORLD_INFO_BATTLE_NAME": "戰鬥",
      "WORLD_INFO_BATTLE_TITLE": "战斗",
      "WORLD_INFO_CULTIVATION_DESC": "修煉可以增加經驗，直到到達突破前的瓶頸。突破是概率事件，突破後會進入下一個境界。",
      "WORLD_INFO_CULTIVATION_NAME": "修煉",
      "WORLD_INFO_CULTIVATION_TITLE": "修炼",
      "WORLD_INFO_DEATH_DESC": "HP降至0以下也會死亡。",
      "WORLD_INFO_DEATH_NAME": "死亡",
      "WORLD_INFO_DEATH_TITLE": "死亡",
      "WORLD_INFO_EQUIPMENT_AND_ELIXIR_DESC": "通過兵器、輔助裝備、丹藥等裝備，可以獲得額外的屬性加成，獲得或小或大的增益。擁有好的裝備或者服用好的丹藥，能獲得很大好處。",
      "WORLD_INFO_EQUIPMENT_AND_ELIXIR_NAME": "裝備與丹藥",
      "WORLD_INFO_EQUIPMENT_AND_ELIXIR_TITLE": "装备与丹药",
      "WORLD_INFO_INTRO_DESC": "這是一個諸多修士競相修行、紛爭四起的修仙世界。",
      "WORLD_INFO_INTRO_NAME": "簡介",
      "WORLD_INFO_INTRO_TITLE": "简介",
      "WORLD_INFO_LIFESPAN_DESC": "若當前年齡達到最大壽元，會立刻死亡。突破境界可以增加最大壽元，突破失敗也可能折損壽元。",
      "WORLD_INFO_LIFESPAN_NAME": "壽元",
      "WORLD_INFO_LIFESPAN_TITLE": "寿元",
      "WORLD_INFO_ORTHODOXY_DESC": "不同的道統有不同的修行方法。道家吐納，武家鍛體，佛家禪定，儒家教化民衆。",
      "WORLD_INFO_ORTHODOXY_NAME": "道統",
      "WORLD_INFO_ORTHODOXY_TITLE": "道統",
      "WORLD_INFO_REALM_DESC": "修仙的境界從弱到強：練氣、築基、金丹、元嬰。每個境界分前期、中期、後期。境界間差距很大。",
      "WORLD_INFO_REALM_NAME": "境界",
      "WORLD_INFO_REALM_TITLE": "境界",
      "WORLD_INFO_REGION_DESC": "不同區域有不同效果，在適當的區域做適當的事情事半功倍。",
      "WORLD_INFO_REGION_NAME": "區域",
      "WORLD_INFO_REGION_TITLE": "区域",
      "WORLD_INFO_ROOT_DESC": "靈根由五行元素（金、木、水、火、土）組成，分爲單靈根、雙靈根和天靈根。五行相剋：金克木，木克土，土克水，水克火，火克金。天靈根包含全部五行元素且突破時有額外加成。在與自身靈根屬性匹配的區域修煉效率最高。",
      "WORLD_INFO_ROOT_NAME": "靈根",
      "WORLD_INFO_ROOT_TITLE": "灵根",
      "WORLD_INFO_SECRET_REALM_DESC": "每隔數年會有祕境開啓。進入祕境可能遭遇兇險，也可能獲得高階法寶和功法。",
      "WORLD_INFO_SECRET_REALM_NAME": "祕境",
      "WORLD_INFO_SECRET_REALM_TITLE": "祕境",
      "WORLD_INFO_SECT_DESC": "修士的庇護所。加入宗門可習得獨門功法、獲同門庇護；散修自由但資源匱乏。",
      "WORLD_INFO_SECT_NAME": "宗門",
      "WORLD_INFO_SECT_TITLE": "宗门",
      "WORLD_INFO_SHOPPING_DESC": "在城市區域可以購買練氣級別丹藥、兵器。購買丹藥後會立刻服用強化自身。購買兵器可以幫自己切換兵器類型爲順手的類型。",
      "WORLD_INFO_SHOPPING_NAME": "購物",
      "WORLD_INFO_SHOPPING_TITLE": "购物",
      "WORLD_INFO_SPIRIT_STONE_DESC": "修仙界的通用貨幣。可用於購買法寶丹藥，通過採集、交易或掠奪獲取。",
      "WORLD_INFO_SPIRIT_STONE_NAME": "靈石",
      "WORLD_INFO_SPIRIT_STONE_TITLE": "灵石",
      "WORLD_INFO_WORLD_QI_DESC": "世界每隔數年會有一次天象變動（如靈氣潮汐），影響角色能力。",
      "WORLD_INFO_WORLD_QI_NAME": "天地靈機",
      "WORLD_INFO_WORLD_QI_TITLE": "天地灵机",
      "WORLD_INFO_RANKING_DESC": "修仙界設有天地人三榜及宗門榜。天榜收錄元嬰期強者，地榜收錄金丹期強者，人榜收錄築基期強者，宗門榜按宗門總實力排名。",
      "WORLD_INFO_RANKING_NAME": "排行榜",
      "WORLD_INFO_RANKING_TITLE": "排行榜",
      "WORLD_INFO_DYNASTY_DESC": "凡人王朝統御天下，維持凡俗秩序與疆域。皇帝壽元與普通凡人無異，駕崩後會有新帝繼位。",
      "WORLD_INFO_DYNASTY_NAME": "王朝",
      "WORLD_INFO_DYNASTY_TITLE": "王朝",
      "WORLD_INFO_OFFICIAL_DESC": "修士可為朝廷理政，積累朝廷威望並領取俸祿。威望足夠可升官，官職越高，俸祿與氣運越多；久不理政，威望會逐漸下滑。",
      "WORLD_INFO_OFFICIAL_NAME": "官職",
      "WORLD_INFO_OFFICIAL_TITLE": "官職"
    }
