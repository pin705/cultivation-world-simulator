msgstr "因{reason_fragment}，{sect_a_name}每地塊年收入修正+{value}（持續{duration_months}個月）。"

msgid "Because {reason_fragment}, {sect_a_name} suffered -{value} income per tile for {duration_months} months."
msgstr "因{reason_fragment}，{sect_a_name}每地塊年收入修正-{value}（持續{duration_months}個月）。"
