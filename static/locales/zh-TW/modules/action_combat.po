# Action: Assassinate
msgid "assassinate_action_name"
msgstr "暗殺"

msgid "assassinate_description"
msgstr "暗殺目標，失敗則變爲戰鬥"

msgid "assassinate_requirements"
msgstr "無限制；需要冷卻"

msgid "assassinate_story_prompt_fail"
msgstr "這是關於一次失敗的暗殺。刺客試圖暗殺目標，但被目標敏銳地察覺了。雙方隨後爆發了激烈的正面衝突。不要出現具體血量數值。"

msgid "assassinate_story_prompt_success"
msgstr "這是關於一次成功的暗殺。不需要描寫戰鬥過程，重點描寫刺客如何潛伏、接近，以及最後那一擊的致命與悄無聲息。目標甚至沒有反應過來就已經隕落。"

# Action: Attack
msgid "attack_action_name"
msgstr "發起戰鬥"

msgid "attack_description"
msgstr "攻擊目標，進行對戰"

msgid "attack_requirements"
msgstr "無限制"

msgid "attack_story_prompt"
msgstr "不要出現具體血量、傷害點數或任何數值表達。戰鬥要體現出雙方的功法、境界、裝備等。"

# Action: Catch
msgid "catch_action_name"
msgstr "御獸"

msgid "catch_description"
msgstr "嘗試馴服一隻靈獸，成爲自身靈獸。只能有一隻靈獸，但是可以高級替換低級"

msgid "catch_requirements"
msgstr "僅百獸宗；在有動物的普通區域；目標動物境界不高於角色"

# Action: DevourMortals
msgid "devour_people_action_name"
msgstr "吞噬生靈"

msgid "devour_people_description"
msgstr "吞噬生靈，較多增加戰力"

msgid "devour_people_requirements"
msgstr "持有萬魂幡"

# Action: Escape
msgid "escape_action_name"
msgstr "逃離"

msgid "escape_description"
msgstr "逃離對方（基於成功率判定）"

msgid "escape_requirements"
msgstr "無限制"

# Action: Hunt
msgid "hunt_action_name"
msgstr "狩獵"

msgid "hunt_description"
msgstr "在當前區域狩獵動物，獲取動物材料"

msgid "hunt_requirements"
msgstr "在有動物的普通區域，且avatar的境界必須大於等於動物的境界"

# Action: PlunderMortals
msgid "plunder_people_action_name"
msgstr "搜刮民脂"

msgid "plunder_people_description"
msgstr "在城鎮搜刮民脂，獲取少量靈石"

msgid "plunder_people_requirements"
msgstr "僅限城市區域，且角色陣營爲'邪'"

msgid "{avatar} assassinated successfully! {target} fell without any defense."
msgstr "{avatar} 暗殺成功！{target} 在毫無防備中隕落。"

msgid "{avatar} begins devouring people in town"
msgstr "{avatar} 在城鎮開始吞噬生靈"

msgid "{avatar} begins plundering people in town"
msgstr "{avatar} 在城鎮開始搜刮民脂"

msgid "{avatar} failed to tame spirit beast"
msgstr "{avatar} 御獸失敗"

msgid "{avatar} lurks in the shadows, attempting to assassinate {target}..."
msgstr "{avatar} 潛伏在陰影中，試圖暗殺 {target}..."
