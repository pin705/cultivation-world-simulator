"{sect_name} spent {cost} spirit stones to recruit {avatar_name}; "
"{avatar_name} officially became a disciple of the sect."
msgstr ""
"{sect_name} đã chi {cost} linh thạch để chiêu nạp {avatar_name}; "
"{avatar_name} chính thức trở thành đệ tử của bổn tông."

msgid ""
"{sect_name} judged that {avatar_name} had gravely violated the sect rules "
"and expelled them from the sect."
msgstr ""
"{sect_name} phán định {avatar_name} đã nghiêm trọng vi phạm môn quy và trục "
"xuất khỏi tông môn."

msgid ""
"{sect_name} bestowed the technique \"{technique_name}\" upon {avatar_name}."
msgstr "{sect_name} đã ban công pháp \"{technique_name}\" cho {avatar_name}."

msgid ""
"{sect_name} granted {amount} spirit stones to {avatar_name} in support of "
"their cultivation."
msgstr ""
"{sect_name} đã cấp {amount} linh thạch cho {avatar_name} để trợ giúp tu "
"hành."

