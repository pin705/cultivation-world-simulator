msgstr "Xác suất đột phá tăng thêm {val:.1%}."

# Action: Breakthrough
msgid "breakthrough_action_name"
msgstr "Đột Phá"

msgid "breakthrough_description"
msgstr ""
"Thử đột phá cảnh giới (thành công sẽ tăng thọ nguyên tối đa, thất bại sẽ làm"
" giảm; cảnh giới càng cao thì xác suất thành công càng thấp)"

msgid "breakthrough_requirements"
msgstr "Nhân vật phải đang ở bình cảnh; không thể liên tục chấp hành"

# Action: Cast
