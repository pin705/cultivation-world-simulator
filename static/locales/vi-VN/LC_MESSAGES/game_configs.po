#. sect.csv: SECT_10_DESC
msgid "SECT_10_DESC"
msgstr ""
"Nhiếp Hồn Âm Tông chiếm cứ Hồi Âm Cốc, nơi cầm lâu, cổ đài, hành lang thí âm"
" và trận trường nhiếp hồn trải dọc theo thế núi. Chỉ cần một cơn gió lùa "
"qua, ngay cả tiếng dây đàn nhỏ nhất cũng có thể bị khuếch đại thành sát cơ "
"đoạt phách. Trong môn chia thành ba nhánh huyễn âm, sát âm và trấn hồn; đệ "
"tử không chỉ học nhạc lý và thuật pháp mà còn phải luyện tiết tấu, hơi thở, "
"dẫn dắt cảm xúc và khống chế thần hồn. Bề ngoài nơi đây phong nhã, nhưng "
"thực chất vô cùng nguy hiểm, đáng sợ nhất thường không phải cơn giận dữ mà "
"là một khúc nhạc dịu dàng rơi xuống đúng lúc."

#. sect.csv: SECT_10_NAME
msgid "SECT_10_NAME"
msgstr "Nhiếp Hồn Âm Tông"

#. sect.csv: SECT_10_RULE_DESC
msgid "SECT_10_RULE_DESC"
msgstr ""
"Ngươi có thể mê hoặc địch nhân, nhưng tuyệt đối không được mất khống chế rồi"
" nhiếp hồn đồng môn hay làm tổn hại căn cơ của tông môn; kẻ bôi nhọ thanh "
"danh bản tông mà vẫn không chịu kiềm chế sẽ bị trục xuất."

#. sect.csv: SECT_11_DESC
msgid "SECT_11_DESC"
msgstr ""
"Thiên Diễn Trận Tông tọa lạc tại Mê Tung Thiên, nơi một ngọn núi duy nhất "
"lại ẩn giấu vô số không gian gấp lớp, chồng lên nhau bởi Diễn Thiên Đài, Vạn"
" Trận Lang, Thí Trận Cốc và địa mạch giếng. Đệ tử nếu không hiểu trận đồ thì"
" ngay cả đường về chỗ ở cũng có thể đi nhầm. Trong tông đại khái phân thành "
"các lộ thiên diễn, địa mạch, khí trận và thủ ngự, ai cũng quen dùng kết quả "
"suy diễn để lên tiếng, từ bố một tiểu trận cho tới cải biến cả sơn hà. Nơi "
"đây rất dễ hấp dẫn những kẻ say mê cấu trúc và quy luật, đồng thời cũng nuôi"
" ra các trận sư lạnh lùng coi nhân tình thế thái chỉ là biến số."

#. sect.csv: SECT_11_NAME
msgid "SECT_11_NAME"
msgstr "Thiên Diễn Trận Tông"

#. sect.csv: SECT_11_RULE_DESC
msgid "SECT_11_RULE_DESC"
msgstr ""
"Ngươi không được dùng trận pháp để gieo tai họa xuống thành trì phàm nhân "
"hay khiến đồng môn chịu phản phệ; nếu sa vào tà đạo mà vẫn không chịu hối "
"cải, sẽ bị trục xuất khỏi tông."

#. sect.csv: SECT_12_DESC
msgid "SECT_12_DESC"
msgstr ""
"Trường Minh Cung nằm giữa Cực Quang Thiên Cảnh của vùng cực bắc vĩnh dạ, nơi"
" Trường Minh Điện, Thánh Hỏa Đàn, Tẩy Tủy Trì và Diệu Giáp Giáo Trường quanh"
" năm được cực quang chiếu sáng. Băng và hỏa cùng tồn tại khiến cả cung thành"
" mang vẻ trang nghiêm gần như thần tích. Tu sĩ trong cung chủ yếu đi theo ba"
" hệ luyện thể, hộ mệnh và trường sinh, vừa trọng quyền cước binh khí, vừa "
"coi trọng dược dục, bí thuật và sự lĩnh ngộ đối với bản nguyên sinh mệnh. Họ"
" tôn sùng ánh sáng, sự bền bỉ và kéo dài, nên thường gánh vác trách nhiệm "
"rất nặng mà vẫn âm thầm chịu đựng."

#. sect.csv: SECT_12_NAME
msgid "SECT_12_NAME"
msgstr "Trường Minh Cung"

#. sect.csv: SECT_12_RULE_DESC
msgid "SECT_12_RULE_DESC"
msgstr ""
"Ngươi không được hãm hại phàm nhân để luyện thể hay bôi nhọ chính đạo quang "
"minh; nếu sa vào tà tu mà vẫn ngoan cố không sửa, sẽ bị trục xuất khỏi cung."

#. sect.csv: SECT_13_DESC
msgid "SECT_13_DESC"
msgstr ""
"Hạo Nhiên Thư Viện tọa lạc trong Thánh Hiền Lâm, nơi giảng kinh đường, Minh "
"Pháp Điện, bia lâm thư khố và vấn tâm thạch kính nằm rải rác giữa rừng. "
"Chuông sớm còn chưa ngân mà tiếng đọc sách đã vang khắp nơi, còn đệ tử qua "
"lại phần nhiều đều áo mũ chỉnh tề, lời nói chừng mực. Trong viện chia thành "
"các hệ kinh nghĩa, pháp lý, trị thế và từ chương; học giả nơi đây không chỉ "
"đọc sách dưỡng khí mà còn nghị chính, biện lý, tu thân và truyền đạo. Nơi "
"này đặc biệt coi trọng khí tiết, danh dự và truyền thừa sư đạo, vì thế vừa "
"có thể nuôi dưỡng quân tử mang chí lớn, vừa dễ sinh ra những người cố chấp "
"không chịu cúi đầu."

#. sect.csv: SECT_13_NAME
msgid "SECT_13_NAME"
msgstr "Hạo Nhiên Thư Viện"

#. sect.csv: SECT_13_RULE_DESC
msgid "SECT_13_RULE_DESC"
msgstr ""
"Ngươi không được khi sư áp dân, cũng không được tự mình lao vào ma đạo; nếu "
"chứng cứ xác thực mà vẫn không chịu hối cải, sẽ bị trục xuất khỏi thư viện."

#. sect.csv: SECT_14_DESC
msgid "SECT_14_DESC"
msgstr ""
"La Sát Huyết Tông thống trị Tu La Huyết Trì, nơi Huyết Hà Tế Đàn, Chiến Công"
" Đường, Luyện Cốt Quật và Đoạt Nguyên Đài ngày đêm vận chuyển giữa màn huyết"
" vụ, dược khí và mùi sắt gỉ dày đặc trong không trung. Nội bộ đại khái chia "
"thành các mạch huyết chiến, tế tu, cướp đoạt và luyện thể, còn tài nguyên "
"thì phân phối trực tiếp theo chiến quả, cống phẩm và hung danh cá nhân. Kẻ "
"mạnh có thể quật khởi cực nhanh, còn kẻ yếu cũng sẽ bị nuốt chửng cực nhanh."
" Đây là nơi tôn sùng trật tự sức mạnh trần trụi nhất, nơi lời nói suông "
"chẳng có giá trị bằng thực lực chứng minh trong máu."

#. sect.csv: SECT_14_NAME
msgid "SECT_14_NAME"
msgstr "La Sát Huyết Tông"

#. sect.csv: SECT_14_RULE_DESC
msgid "SECT_14_RULE_DESC"
msgstr ""
"Ngươi có thể tranh đấu và cướp đoạt, nhưng tuyệt đối không được phản bội "
"Huyết Tông, biển thủ chiến lợi phẩm hay dùng tà thuật đối phó người của bản "
"môn; bất kỳ ai phạm trọng cấm này đều sẽ bị trục xuất."

#. sect.csv: SECT_1_DESC
msgid "SECT_1_DESC"
msgstr ""
"Lăng Tiêu Kiếm Tông tọa lạc giữa quần phong Tuyệt Vân, nơi sơn môn, kiếm các"
" và đài thí kiếm tầng tầng vươn cao trong cương phong gào thét quanh năm. "
"Trong tông có các mạch ngự kiếm, lôi kiếm và dưỡng kiếm cùng tồn tại; đệ tử "
"sáng tối đều phải trèo vách vấn kiếm, đối chiếu sở ngộ trước kiếm bia. Nơi "
"đây tôn sùng sự sắc bén và thuần túy, coi trọng thanh danh lẫn ngộ tính, vì "
"thế thường sinh ra cả kỳ tài một trận thành danh lẫn những kiếm tu cô ngạo "
"bị chấp niệm trói chặt."

#. sect.csv: SECT_1_NAME
msgid "SECT_1_NAME"
msgstr "Lăng Tiêu Kiếm Tông"

#. sect.csv: SECT_1_RULE_DESC
msgid "SECT_1_RULE_DESC"
msgstr ""
"Ngươi tuyệt đối không được thông đồng với tà ma hay tàn sát kẻ vô tội; nếu "
"sa vào ma đạo mà sau nhiều lần răn dạy vẫn không chịu sửa đổi, sẽ bị trục "
"xuất khỏi sơn môn."

#. sect.csv: SECT_2_DESC
msgid "SECT_2_DESC"
msgstr ""
"Vạn Thú Ma Sơn ẩn sâu trong Thập Vạn Đại Sơn, nơi chín mươi chín tầng động "
"thiên nuôi nhốt một quần thể linh thú và yêu vương vô cùng đồ sộ. Chuồng "
"thú, huyết thực trường và đàn khế linh ngày đêm chẳng lúc nào yên. Đệ tử "
"trong tông phần lớn chia thành ba đường ngự thú, dưỡng thú và luyện huyết; "
"có người coi yêu thú là bạn đồng hành, cũng có kẻ chỉ xem chúng như chiến "
"lực có thể hao tổn. Bầu không khí nơi đây nguyên sơ mà cường hoành, dạy "
"người ta dùng thực lực áp phục vạn thú và mài giũa bản năng sinh tồn từ "
"chính thú tính."

#. sect.csv: SECT_2_NAME
msgid "SECT_2_NAME"
msgstr "Vạn Thú Ma Sơn"

#. sect.csv: SECT_2_RULE_DESC
msgid "SECT_2_RULE_DESC"
msgstr ""
"Ngươi có thể chém giết tranh đấu, nhưng không được phản bội sơn môn, cấu kết"
" ngoại địch hay để thú nuôi quay lại làm hại đồng môn; kẻ phạm trọng cấm này"
" sẽ bị trục xuất."

#. sect.csv: SECT_3_DESC
msgid "SECT_3_DESC"
msgstr ""
"Thính Đào Các đứng trên tuyệt bích Tĩnh Hải Nhai, nơi lầu các làm bằng hàn "
"băng linh ngọc phản chiếu triều dâng cùng tinh huy. Bảo vật quan trọng nhất "
"ở đây không phải binh khí mà là Quan Hải Ngọc Bích, đài quan triều và tinh "
"bàn dùng để suy diễn thiên cơ. Đệ tử tu tập các pháp quan tinh, thính triều "
"và vấn quái, thường ít lời ít động nhưng lại rất giỏi từ gió, thủy triều và "
"những biến chuyển rất nhỏ trong lòng người mà nhìn ra điềm báo. Cả các luôn "
"mang cảm giác thanh lãnh xa cách, như thể ai cũng nhìn thế gian qua một lớp "
"sương mờ."

#. sect.csv: SECT_3_NAME
msgid "SECT_3_NAME"
msgstr "Thính Đào Các"

#. sect.csv: SECT_3_RULE_DESC
msgid "SECT_3_RULE_DESC"
msgstr ""
"Ngươi không được vì tư tâm mà quấy nhiễu việc bói toán của các, cũng không "
"được bán đứng thiên cơ của tông môn; nếu tình tiết đặc biệt nghiêm trọng, sẽ"
" bị trục xuất."

#. sect.csv: SECT_4_DESC
msgid "SECT_4_DESC"
msgstr ""
"Cửu U Hoàng Tuyền Đạo chiếm cứ quần đảo Tử Tịch Hải, nơi giữa sơn môn dựng "
"nên Dẫn Hồn Điện, Độ Hồn Kiều, Trấn Thi Khố và hành lang u đăng quanh năm "
"chìm trong hải vụ. Bước chân ra vào nơi này đều giống như đi giữa khe nứt "
"của sinh tử. Nội bộ có các mạch luyện hồn, độ tử và âm thuật; đệ tử tu hành "
"thường xuyên bên cạnh vong hồn, thi khôi và âm hà chi khí nên có nhận thức "
"về luân chuyển sinh tử khác hẳn người thường. Nơi đây trật tự nghiêm ngặt, "
"bầu không khí u lãnh, dễ nuôi dưỡng những tâm tính lạnh lùng đến mức coi vạn"
" vật đều chỉ là cái giá phải trả."

#. sect.csv: SECT_4_NAME
msgid "SECT_4_NAME"
msgstr "Cửu U Hoàng Tuyền Đạo"

#. sect.csv: SECT_4_RULE_DESC
msgid "SECT_4_RULE_DESC"
msgstr ""
"Ngươi có thể tu luyện âm pháp, nhưng tuyệt đối không được trái lệnh sư "
"trưởng hay tự ý cướp hồn làm hại đồng môn; kẻ phạm trọng quy này sẽ bị trục "
"xuất."

#. sect.csv: SECT_5_DESC
msgid "SECT_5_DESC"
msgstr ""
"Thiên Cơ Quỷ Môn ẩn mình trong sâu thẳm Thiên Cơ Cốc. Từ bên ngoài, đài tạ "
"lầu các tinh xảo mà hoa lệ, nhưng bên trong lại ken dày hành lang cơ quan, "
"phường khôi lỗi, kho độc khí và mật đạo tối tăm, đến từng viên gạch mái ngói"
" cũng có thể giấu sát cơ. Đệ tử trong môn thường chia thành cơ quan sư, khôi"
" lỗi sư, độc sư và ẩn hành khách, vừa phải biết chế tác, vừa phải biết phục "
"kích, còn phải học cách tự bảo toàn trong im lặng. Nơi đây đề cao hiệu suất,"
" bí mật và kết quả, vì vậy rất dễ sinh ra thiên tài mưu toán cùng những mối "
"quan hệ luôn căng như dây đàn."

#. sect.csv: SECT_5_NAME
msgid "SECT_5_NAME"
msgstr "Thiên Cơ Quỷ Môn"

#. sect.csv: SECT_5_RULE_DESC
msgid "SECT_5_RULE_DESC"
msgstr ""
"Ngươi không được tiết lộ bản vẽ cơ quan bí mật hay ám sát người của bản môn;"
" nếu cấu kết với chính đạo rồi quay lưng với tông môn, sẽ bị trục xuất."

#. sect.csv: SECT_6_DESC
msgid "SECT_6_DESC"
msgstr ""
"Túy Mộng Lâu được dựng trong động thiên giữa chốn phồn hoa, nơi hương các, "
"thủy tạ, nhạc phường và Huyễn Mộng Trì liên kết với nhau dưới tiếng ca vũ "
"ban ngày và ánh đèn rực rỡ ban đêm. Tu hành ở đây không chỉ dựa vào song tu "
"mà còn coi trọng hương đạo, âm luật, vũ pháp, đàm phán và khả năng quan sát "
"lòng người; đệ tử thường kiêm tu mị thuật, nhạc thuật cùng thủ đoạn tình "
"báo. Tông môn này giỏi nhất ở chỗ biến dục vọng hồng trần thành tư lương tu "
"hành, nhưng cũng khiến người ta dễ lạc trong ranh giới giữa chân tình và lợi"
" dụng."

#. sect.csv: SECT_6_NAME
msgid "SECT_6_NAME"
msgstr "Túy Mộng Lâu"

#. sect.csv: SECT_6_RULE_DESC
msgid "SECT_6_RULE_DESC"
msgstr ""
"Ngươi có thể đắm mình trong chốn hồng trần, nhưng không được hái bổ người "
"khác đến chết hay phản bội sư môn tổ tông; kẻ phạm trọng giới này sẽ bị trục"
" xuất."

#. sect.csv: SECT_7_DESC
msgid "SECT_7_DESC"
msgstr ""
"Tu Di Thiền Viện tọa lạc trên Phổ Độ Đảo giữa Phong Bạo Hải, lấy Kim Cang "
"Tháp làm trung tâm, xung quanh là Phục Ma Điện, thính chung đài, khổ tu nhai"
" và dược dục trì. Mỗi khi tiếng chuông ngân lên, cả hòn đảo như bị phật "
"quang vô hình trấn giữ. Trong viện có ba đường thiền tu, võ tu và hộ pháp; "
"đệ tử vừa phải tụng kinh, vừa phải luyện thể, lại thường được phái đi trấn "
"áp yêu tà ngoài hải vực và tiếp dẫn người gặp nạn. Bề ngoài nơi đây trang "
"nghiêm túc mục, nhưng bên trong không hề khô cứng, bởi nhiều tăng tu vẫn "
"mang trong lòng chí nguyện nhập thế cứu người."

#. sect.csv: SECT_7_NAME
msgid "SECT_7_NAME"
msgstr "Tu Di Thiền Viện"

#. sect.csv: SECT_7_RULE_DESC
msgid "SECT_7_RULE_DESC"
msgstr ""
"Tùy tiện giết hại phàm nhân, cấu kết với tà linh hay tàn hại đồng môn đều bị"
" nghiêm cấm; kẻ phạm trọng tội mà vẫn không chịu hối cải sẽ bị trục xuất."

#. sect.csv: SECT_8_DESC
msgid "SECT_8_DESC"
msgstr ""
"Ảnh Sát Điện ẩn phục sâu trong Ám Ảnh Chiểu Trạch, nơi phía trên tán cây có "
"ẩn lâu, dưới bùn lầy có mật đạo, còn Ảnh Lao, Ẩn Hình Trường, độc chướng đàm"
" và các cứ điểm tình báo thì chồng lớp lên nhau. Người ngoài rất khó nhìn rõ"
" bộ dạng thật của nơi này. Đệ tử trong điện thường chia thành các tuyến tiềm"
" thích, độn hành, trinh tập và thu thi xử lý hậu sự, từ lúc nhập môn đã phải"
" học cách giấu tung tích, cắt đứt dấu vết và thoát thân trong tuyệt cảnh. "
"Nơi đây gần như không có chút ấm áp dư thừa nào, nhưng chính sự lạnh lẽo ấy "
"lại rèn ra thứ ăn ý chỉ hiện ra bên bờ sinh tử."

#. sect.csv: SECT_8_NAME
msgid "SECT_8_NAME"
msgstr "Ảnh Sát Điện"

#. sect.csv: SECT_8_RULE_DESC
msgid "SECT_8_RULE_DESC"
msgstr ""
"Ám sát được cho phép, nhưng không được đâm sau lưng người của bản điện hay "
"tiết lộ cứ điểm bí mật; nếu đầu nhập chính đạo rồi bán đứng đồng môn, sẽ bị "
"trục xuất."

#. sect.csv: SECT_9_DESC
msgid "SECT_9_DESC"
msgstr ""
"Vạn Bảo Tiên Minh được dựng trên quần đảo Đa Bảo Phù Không, nơi điện đấu "
"giá, Thiên Lô Tháp, cảng vân chu, tổng khố và đủ loại thương quán nối liền "
"với nhau thành một tòa tiên thành không bao giờ nghỉ. Tu sĩ trong minh vừa "
"tu luyện vừa kinh thương, chia thành các hệ luyện khí, giám bảo, hàng vận, "
"kế toán và ngoại thương; rất nhiều đệ tử từ nhỏ đã phải học định giá, trả "
"giá, lập khế và duy trì thương lộ. Bầu không khí nơi đây thực tế hơn đa số "
"tông môn khác, bởi ai cũng hiểu tài nguyên có thể chuyển thành quyền thế như"
" thế nào."

#. sect.csv: SECT_9_NAME
msgid "SECT_9_NAME"
msgstr "Vạn Bảo Tiên Minh"

#. sect.csv: SECT_9_RULE_DESC
msgid "SECT_9_RULE_DESC"
msgstr ""
"Ngươi có thể theo đuổi lợi ích, nhưng không được biển thủ tài khố của tông "
"môn hay bán đứng tiên minh cho kẻ địch; nếu tội đặc biệt nặng nề sẽ bị trục "
"xuất."

#. sect_region.csv: SECT_REGION_401_DESC
msgid "SECT_REGION_401_DESC"
msgstr ""
"Quần phong Tuyệt Vân đâm thẳng vào biển mây, các ngọn núi nối với nhau bằng "
"xích sắt và vân kiều, đường núi hiểm trở đến mức chỉ những ai thật sự ổn "
"định được kiếm ý mới có thể bước lên tầng cao hơn. Lưng chừng núi có thể "
"thấy thí kiếm đài, tẩy kiếm trì và từng mảng vách đá chằng chịt kiếm ngân; "
"càng lên gần đỉnh, tiếng gió càng sắc, thỉnh thoảng còn có lôi quang xẹt "
"ngang sườn núi. Cả sơn môn giống như một thanh cổ kiếm đã rút khỏi vỏ mà "
"chưa từng quay về, thanh hàn và đầy phong mang."

#. sect_region.csv: SECT_REGION_401_NAME
msgid "SECT_REGION_401_NAME"
msgstr "Tuyệt Vân Phong"

#. sect_region.csv: SECT_REGION_402_DESC
msgid "SECT_REGION_402_DESC"
msgstr ""
"Vạn Thú Quật ẩn sâu trong bụng núi, bên ngoài bị chướng khí và dây leo phong"
" kín như một tấm lá chắn tự nhiên. Chỉ khi tiến sâu vào trong mới thấy được "
"các tầng động thiên thú vực đang dần chìm xuống. Từng tầng động được ngăn "
"bằng thạch kiều, thiết áp và ngự thú đài, còn tiếng thú gầm trầm thấp cùng "
"âm thanh xích sắt va chạm thì vang dội suốt ngày đêm. Xương vụn, dấu vuốt và"
" yêu khí chưa tan rải đầy mặt đất. Nơi này không giống sơn môn bình thường, "
"mà giống một thành sào huyệt của cự thú đang sống."

#. sect_region.csv: SECT_REGION_402_NAME
msgid "SECT_REGION_402_NAME"
msgstr "Vạn Thú Quật"

#. sect_region.csv: SECT_REGION_403_DESC
msgid "SECT_REGION_403_DESC"
msgstr ""
"Tĩnh Hải Nhai treo mình trên vách biển cao vạn trượng, nơi điện các, hành "
"lang và đài quan triều bằng hàn băng linh ngọc nửa ẩn nửa hiện giữa màn "
"sương biển. Từ xa nhìn lại, cả sơn môn như đang lơ lửng trong tiếng sóng và "
"ánh trăng. Ngọc bích bên bờ vực phản chiếu tinh quang cùng biển trời, còn "
"mỗi lần thủy triều lên xuống, tường và mặt đất lại nổi lên quầng sáng như "
"gợn nước khiến đường đi trở nên hư thực khó phân. Nơi đây yên tĩnh đến mức "
"gần như trống không, chỉ còn tiếng sóng, tiếng gió và tiếng chuông lướt qua "
"mái hiên nhắc người ta rằng mình vẫn còn ở nhân gian."

#. sect_region.csv: SECT_REGION_403_NAME
msgid "SECT_REGION_403_NAME"
msgstr "Tĩnh Hải Nhai"

#. sect_region.csv: SECT_REGION_404_DESC
msgid "SECT_REGION_404_DESC"
msgstr ""
"Tử Tịch Hải được tạo thành từ những hòn đảo đen và các vịnh triều ngầm, nối "
"với nhau bằng cầu ván hẹp, bến đá tàn bia và hải đăng ma hỏa, nhìn từ xa như"
" một quỷ thành trôi trên mặt biển mực đen. Mặt nước quanh năm vô phong mà "
"vẫn nổi sóng, mỗi con triều dựng lên lại kèm theo âm thanh rít gào như tiếng"
" khóc xa xăm. Điện vũ và bậc đá trên đảo bị sương ẩm nhuộm thành màu xám "
"trắng lẫn u thanh. Ban đêm, thứ nổi bật nhất không phải ánh trăng mà là từng"
" ngọn dẫn hồn đăng chập chờn trong sương biển."

#. sect_region.csv: SECT_REGION_404_NAME
msgid "SECT_REGION_404_NAME"
msgstr "Tử Tịch Hải"

#. sect_region.csv: SECT_REGION_405_DESC
msgid "SECT_REGION_405_DESC"
msgstr ""
"Thoạt nhìn, Thiên Cơ Cốc chỉ như một sơn cốc bình thường với đường đá xanh, "
"phi diêm lầu các và đình viện hoa cỏ được bài trí rất tinh xảo. Nhưng đến "
"gần mới nhận ra cầu có thể tự đổi hướng, tường có thể mở khép, ngay cả bậc "
"thang lên xuống cũng ẩn cơ quát. Trên cao là vọng lâu và huyền kiều, dưới "
"thấp là ám đạo, công phường và mật thất, thỉnh thoảng còn vang lên tiếng "
"răng truyền ăn khớp, kim loại rung nhẹ hoặc bước chân mộc ngẫu từ nơi vô "
"định. Điều đáng sợ nhất ở đây không phải một bẫy nào đó, mà là cả sơn cốc "
"chính là một cỗ cơ quan khổng lồ."

#. sect_region.csv: SECT_REGION_405_NAME
msgid "SECT_REGION_405_NAME"
msgstr "Thiên Cơ Cốc"

#. sect_region.csv: SECT_REGION_406_DESC
msgid "SECT_REGION_406_DESC"
msgstr ""
"Tiêu Kim Quật ẩn trong một động thiên riêng phía sau khu phố phồn hoa, cửa "
"vào là biển đèn, hương sương, khúc kiều và từng lớp lầu các thủy tạ chồng "
"lên nhau. Càng đi sâu, tiếng náo nhiệt càng lùi lại, nhường chỗ cho tiếng "
"nước và nhạc âm dai dẳng quấn người. Tầng ngoài rực vàng ngọc, khách khứa "
"như mắc cửi; bên trong lại có tĩnh thất, ôn tuyền và Huyễn Mộng Trì được "
"ngăn bởi lụa mỏng, hoa tường và mây khói, đến cả con đường cũng như cố ý "
"khiến người ta lạc lối. Đẹp đẽ, xa hoa là thế, nhưng khó ai nói rõ mình đang"
" dự yến, nhập mộng hay bước vào một loại tu hành khác."

#. sect_region.csv: SECT_REGION_406_NAME
msgid "SECT_REGION_406_NAME"
msgstr "Tiêu Kim Quật"

#. sect_region.csv: SECT_REGION_407_DESC
msgid "SECT_REGION_407_DESC"
msgstr ""
"Phổ Độ Đảo cô treo giữa Phong Bạo Hải, bên ngoài là sóng dữ ngập trời và "
"điện quang cuồn cuộn, còn bên trong lại bị tiếng chuông cùng phật quang ép "
"thành một vùng tĩnh mịch gần như đông cứng. Kim Cang Tháp đứng giữa đảo, "
"xung quanh là phật điện, bậc đá, đài khổ tu trên vách biển và bến giáp biển."
" Kim linh trên đỉnh tháp rung dài theo gió biển, dường như có thể xoa dịu "
"cơn bão từng chút một. Mỗi khi sương sớm tan đi, kim quang rắc lên đá ngầm "
"đen cùng điện các xanh trắng, cả hòn đảo trông như một pháp ấn trấn tà nổi "
"lên từ biển giận."

#. sect_region.csv: SECT_REGION_407_NAME
msgid "SECT_REGION_407_NAME"
msgstr "Phổ Độ Đảo"

#. sect_region.csv: SECT_REGION_408_DESC
msgid "SECT_REGION_408_DESC"
msgstr ""
"Ám Ảnh Chiểu Trạch quanh năm không thấy thiên quang, độc vụ, nước thối và cổ"
" mộc quấn rễ bịt kín toàn bộ địa vực. Người ngoài thường chưa kịp nhìn thấy "
"sơn môn đã bị những bóng tối vô hình dõi theo. Căn cứ thật sự không tập "
"trung trên mặt đất: giữa tán cây ẩn giấu lâu các và cầu treo, còn dưới bùn "
"lầy lại là mật đạo, ám thất và những lối vào bị chướng khí che khuất. Nơi "
"đây gần như không có tầm nhìn thoáng đãng hoàn chỉnh nào, chỉ có đăng quang "
"lạnh chập chờn, sương mù trôi dạt và dòng hắc thủy có thể nuốt mất tiếng "
"bước chân bất cứ lúc nào."

#. sect_region.csv: SECT_REGION_408_NAME
msgid "SECT_REGION_408_NAME"
msgstr "Ám Ảnh Chiểu Trạch"

#. sect_region.csv: SECT_REGION_409_DESC
msgid "SECT_REGION_409_DESC"
msgstr ""
"Đa Bảo Phù Không Đảo không phải một hòn đảo đơn lẻ mà là cả quần đảo lơ lửng"
" với kích cỡ khác nhau, nối với nhau bằng cự liên, vân kiều và hàng tuyến "
"của phi chu, hợp thành một tòa tiên thành treo giữa trời cao. Vòng ngoài là "
"vân chu cảng và bãi hàng luôn tấp nập, tầng giữa là phố buôn, lâu đấu giá và"
" phường thị, còn nơi cao nhất dựng đầy luyện khí cao tháp phun lò hỏa suốt "
"ngày đêm. Khi màn đêm buông xuống, ánh đèn chạy dọc theo xích sắt và không "
"kiều tới tận tầng mây, khiến cả vùng đất này giống như một mạng lưới thương "
"nghiệp bằng vàng trải khắp bầu trời."

#. sect_region.csv: SECT_REGION_409_NAME
msgid "SECT_REGION_409_NAME"
msgstr "Đa Bảo Phù Không Đảo"

#. sect_region.csv: SECT_REGION_410_DESC
msgid "SECT_REGION_410_DESC"
msgstr ""
"Hồi Âm Cốc bị hai vách núi cao ép hẹp vào trong, tự nhiên hình thành vô số "
"lỗ hồi hưởng và khe cộng chấn, khiến chỉ một tiếng gảy đàn thôi cũng có thể "
"xoáy chuyển rất lâu không dứt. Trong cốc, đình đài, thủy tạ, cầm lâu và hành"
" lang bày theo thế núi, còn suối thì xuyên qua lầu mà chảy. Bề ngoài nơi đây"
" tao nhã như tiên gia biệt uyển, nhưng nếu lắng nghe kỹ sẽ thấy gió lướt qua"
" mái hiên hay giọt nước rơi xuống đầm đều như đã bị một bàn tay vô hình sắp "
"xếp lại tiết tấu. Nguy hiểm nhất ở đây thường là lúc cả cốc bỗng im lặng "
"hẳn."

#. sect_region.csv: SECT_REGION_410_NAME
msgid "SECT_REGION_410_NAME"
msgstr "Hồi Âm Cốc"

#. sect_region.csv: SECT_REGION_411_DESC
msgid "SECT_REGION_411_DESC"
msgstr ""
"Mê Tung Thiên bề ngoài chỉ là một cô phong, nhưng khi thật sự bước vào sơn "
"môn mới phát hiện đình đài, bậc đá, huyền kiều và sơn đạo đều được cài trong"
" từng tầng không gian gấp lớp. Cùng một con đường mà nhìn từ trước và sau có"
" thể hoàn toàn khác nhau. Trên sườn núi có quảng trường khắc đầy trận văn, "
"hành lang nổi giữa không trung và các lầu các lúc ẩn lúc hiện, còn dưới chân"
" thì thỉnh thoảng lóe lên những đường sáng như thể cả ngọn núi đang chậm rãi"
" suy nghĩ. Ở đây chẳng có phương hướng nào thật sự ổn định; mỗi bước đi đều "
"như tiến vào một tầng thiên địa khác."

#. sect_region.csv: SECT_REGION_411_NAME
msgid "SECT_REGION_411_NAME"
msgstr "Mê Tung Thiên"

#. sect_region.csv: SECT_REGION_412_DESC
msgid "SECT_REGION_412_DESC"
msgstr ""
"Cực Quang Thiên Cảnh nằm sâu trong vùng cực bắc vĩnh dạ, bên ngoài là băng "
"nguyên dài dằng dặc và im lìm, chỉ riêng cung thành này quanh năm được cực "
"quang lưu động chiếu sáng như ban ngày. Tường băng cao lớn, huyền thiết cung"
" môn, băng kiều và giáo trường đều phản chiếu hàn quang lạnh lẽo dưới màn "
"sáng, còn sâu trong thành, Thánh Hỏa Đàn lại nhuộm cả vùng lạnh giá thành "
"một màu đỏ ấm không bao giờ tắt. Vẻ động lòng nhất của nơi đây không chỉ là "
"tráng lệ, mà là trật tự trong đó băng và hỏa, tĩnh và minh cùng tồn tại."

#. sect_region.csv: SECT_REGION_412_NAME
msgid "SECT_REGION_412_NAME"
msgstr "Cực Quang Thiên Cảnh"

#. sect_region.csv: SECT_REGION_413_DESC
msgid "SECT_REGION_413_DESC"
msgstr ""
"Thánh Hiền Lâm nằm ở nơi linh mạch giao hội giữa trung vực, cổ mộc vươn "
"trời, bia lâm phân tán, còn giảng đường, thư các và tiểu viện bên nước thì "
"ẩn hiện dưới bóng cây. Người đi qua đây thường phải bước trên thạch kính phủ"
" lá rụng và xuyên qua hành lang khắc đầy cổ văn. Ban ngày, tiếng đọc sách "
"theo gió rừng truyền đi rất xa; ban đêm, bia văn lại phát ra ánh sáng yếu "
"dưới trăng, khiến bóng cây và mái hiên càng thêm tĩnh mặc. Nơi này không "
"giống một sơn môn khép kín, mà giống một học cung đang tiếp tục lớn lên cùng"
" thời gian."

#. sect_region.csv: SECT_REGION_413_NAME
msgid "SECT_REGION_413_NAME"
msgstr "Thánh Hiền Lâm"

#. sect_region.csv: SECT_REGION_414_DESC
msgid "SECT_REGION_414_DESC"
msgstr ""
"Ngọn núi nơi Tu La Huyết Trì tọa lạc mang màu đỏ thẫm từ trong ra ngoài, "
"những khe đá luôn trào lên huyết vụ cùng nhiệt lưu, còn sâu trong lòng núi "
"thì bị khoét thành huyết trì ngầm khổng lồ và các điện vũ tế trường chồng "
"lớp lên nhau. Thiết tác kiều bắc ngang huyết hà, bậc đá dẫn thẳng xuống "
"chiến đài, cốt quật và tế đàn đang rực sáng trong xích quang. Càng đi sâu "
"xuống lòng đất, mùi sắt gỉ, dược khí và huyết tinh ẩm ướt càng nặng. Toàn bộ"
" nơi này giống như một con hung thú đang chậm rãi hô hấp dưới mặt đất."

#. sect_region.csv: SECT_REGION_414_NAME
msgid "SECT_REGION_414_NAME"
msgstr "Tu La Huyết Trì"

#. technique.csv: 最基础的法术，凝聚火炎伤敌，简单实用。...
msgid "TECHNIQUE_10_DESC"
msgstr ""
"Pháp thuật cơ bản nhất, ngưng tụ hỏa viêm để đả thương địch nhân, đơn giản "
"mà thực dụng."

#. technique.csv: 火灵诀
msgid "TECHNIQUE_10_NAME"
msgstr "Hỏa Linh Quyết"

#. technique.csv: 纯阳之气，刚猛无铸，克制阴邪。...
msgid "TECHNIQUE_11_DESC"
msgstr "Thuần dương chi khí cương mãnh vô song, khắc chế âm tà."

#. technique.csv: 纯阳真功
msgid "TECHNIQUE_11_NAME"
msgstr "Thuần Dương Chân Công"

#. technique.csv: 力能扛鼎，气力悠长，如下山猛虎。...
msgid "TECHNIQUE_13_DESC"
msgstr ""
"Sức lực đủ để nhấc đỉnh, khí lực kéo dài lâu bền, mạnh như mãnh hổ xuống "
"núi."

#. technique.csv: 搬山诀
msgid "TECHNIQUE_13_NAME"
msgstr "Bàn Sơn Quyết"

#. technique.csv: 不动如山，动如雷震，佛门护法神功。...
msgid "TECHNIQUE_14_DESC"
msgstr "Bất động như sơn, động như lôi chấn, là Phật môn hộ pháp thần công."

#. technique.csv: 不动明王诀
msgid "TECHNIQUE_14_NAME"
msgstr "Bất Động Minh Vương Quyết"

#. technique.csv: 心若冰清，天塌不惊，凝神静气。...
msgid "TECHNIQUE_16_DESC"
msgstr "Tâm như băng thanh, trời sập không kinh, ngưng thần tĩnh khí."

#. technique.csv: 凝神冰心诀
msgid "TECHNIQUE_16_NAME"
msgstr "Ngưng Thần Băng Tâm Quyết"

#. technique.csv: 寒气透骨，冻结经脉，阴狠霸道。...
msgid "TECHNIQUE_17_DESC"
msgstr "Hàn khí thấu cốt, đóng băng kinh mạch, âm hiểm mà bá đạo."

#. technique.csv: 玄冰劲
msgid "TECHNIQUE_17_NAME"
msgstr "Huyền Băng Kình"

#. technique.csv: 身法灵动，变幻莫测，逃跑一流。...
msgid "TECHNIQUE_19_DESC"
msgstr ""
"Thân pháp linh động, biến hóa khó lường, là nhất lưu trong việc thoát thân."

#. technique.csv: 流云百变身
msgid "TECHNIQUE_19_NAME"
msgstr "Lưu Vân Bách Biến Thân"

#. technique.csv: 佛门护教神功，浑身坚若金石，寻常兵刃难伤。
msgid "TECHNIQUE_1_DESC"
msgstr ""
"Phật môn hộ giáo thần công, toàn thân cứng như kim thạch, binh khí bình "
"thường khó lòng làm tổn thương."

#. technique.csv: 混元金身
msgid "TECHNIQUE_1_NAME"
msgstr "Hỗn Nguyên Kim Thân"

#. technique.csv: 借力腾空，左脚踩右脚，直上青云九霄。
msgid "TECHNIQUE_20_DESC"
msgstr ""
"Mượn lực bay vút lên không trung, chân trái đạp chân phải, một bước thẳng "
"lên tận cửu tiêu."

#. technique.csv: 踏云步
msgid "TECHNIQUE_20_NAME"
msgstr "Đạp Vân Bộ"

#. technique.csv: 收敛气息，如枯木死灰，令人难以察觉。...
msgid "TECHNIQUE_22_DESC"
msgstr ""
"Thu liễm khí tức như khô mộc tàn tro, khiến người khác khó lòng phát giác."

#. technique.csv: 敛息术
msgid "TECHNIQUE_22_NAME"
msgstr "Liễm Tức Thuật"

#. technique.csv: 如鬼魅般难以捉摸，步法诡异，令人眼花缭乱。
msgid "TECHNIQUE_23_DESC"
msgstr "Quỷ dị như mị ảnh, bộ pháp quỷ quyệt, khiến người hoa mắt chóng mặt."

#. technique.csv: 幻影迷踪步
msgid "TECHNIQUE_23_NAME"
msgstr "Huyễn Ảnh Mê Tung Bộ"

#. technique.csv: 道家正宗法术，掌心发雷，震慑妖邪。...
msgid "TECHNIQUE_25_DESC"
msgstr ""
"Đạo gia chính tông pháp thuật, phát lôi nơi lòng bàn tay, chấn nhiếp yêu tà."

#. technique.csv: 掌心雷
msgid "TECHNIQUE_25_NAME"
msgstr "Chưởng Tâm Lôi"

#. technique.csv: 役使五行之雷，刚猛霸道，无坚不摧。...
msgid "TECHNIQUE_26_DESC"
msgstr "Điều động ngũ hành chi lôi, cương mãnh bá đạo, vô kiên bất tồi."

#. technique.csv: 五雷正法
msgid "TECHNIQUE_26_NAME"
msgstr "Ngũ Lôi Chính Pháp"

#. technique.csv: 燃烧精血，短暂爆发实力，事后虚弱。...
msgid "TECHNIQUE_28_DESC"
msgstr ""
"Thiêu đốt tinh huyết để đổi lấy bộc phát thực lực trong thời gian ngắn, sau "
"đó rơi vào suy yếu."

#. technique.csv: 燃血爆元术
msgid "TECHNIQUE_28_NAME"
msgstr "Nhiên Huyết Bạo Nguyên Thuật"

#. technique.csv: 强行吸取他人灵力为己用，霸道异常，常有反噬风险。
msgid "TECHNIQUE_29_DESC"
msgstr ""
"Cưỡng ép hấp thu linh lực của người khác cho bản thân sử dụng, bá đạo vô "
"cùng và thường tiềm ẩn nguy cơ phản phệ."

#. technique.csv: 吞灵归元功
msgid "TECHNIQUE_29_NAME"
msgstr "Thôn Linh Quy Nguyên Công"

#. technique.csv: 运气成钟，护持周身，反震外力。...
msgid "TECHNIQUE_2_DESC"
msgstr "Vận khí thành chung, hộ trì toàn thân, phản chấn ngoại lực."

#. technique.csv: 金钟罩
msgid "TECHNIQUE_2_NAME"
msgstr "Kim Chung Tráo"

#. technique.csv: 一剑枯荣，斩尽日月星辰，乃剑道至高境界。
msgid "TECHNIQUE_30_DESC"
msgstr ""
"Một kiếm khô vinh, chém tận nhật nguyệt tinh thần, là cảnh giới tối cao của "
"kiếm đạo."

#. technique.csv: 斩星枯荣剑
msgid "TECHNIQUE_30_NAME"
msgstr "Trảm Tinh Khô Vinh Kiếm"

