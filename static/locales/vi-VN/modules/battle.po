# Battle messages
msgid ""
"{winner} defeated {loser}, dealing {damage} damage. {loser} was fatally "
"wounded and perished."
msgstr ""
"{winner} đánh bại {loser}, gây ra {damage} điểm thương hại. {loser} trọng "
"thương trí mạng và tại chỗ vẫn lạc."

msgid ""
"{winner} defeated {loser}. {loser} took {loser_dmg} damage, {winner} also "
"took {winner_dmg} damage."
msgstr ""
"{winner} đánh bại {loser}. {loser} chịu {loser_dmg} điểm thương hại, còn "
"{winner} cũng chịu {winner_dmg} điểm thương hại."
