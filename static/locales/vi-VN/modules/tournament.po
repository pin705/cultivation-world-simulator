msgid "tournament_battle_result"
msgstr "Trong trận tỷ đấu võ đạo hội, {winner} đã đánh bại {loser}."

msgid "tournament_end_heaven"
msgstr ""
"Thiên bảng võ đạo hội đã kết thúc. Hạng nhất thuộc về: {winner}."

msgid "tournament_end_earth"
msgstr "Địa bảng võ đạo hội đã kết thúc. Hạng nhất thuộc về: {winner}."

