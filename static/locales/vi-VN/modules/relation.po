msgid "relation_rule_apprentice_add"
msgstr ""
"[Đồ Đệ] Xét theo phía sư phụ, quan hệ này thường được thiết lập tự động "
"cùng với quan hệ sư phụ."

msgid "relation_rule_apprentice_cancel"
msgstr "[Xuất Sư / Đoạn Tuyệt] Tương tự như trên."

msgid "relation_rule_cancel_title"
msgstr "[Quy Tắc Hủy Quan Hệ]"

msgid "relation_rule_enemy_add"
msgstr ""
"[Căm Ghét] Đã xảy ra tổn hại thực chất như bị thương, trộm cắp hoặc làm nhục. "
"Có thể là một lần tổn hại nghiêm trọng hoặc nhiều lần xung đột nhỏ."

msgid "relation_rule_enemy_cancel"
msgstr ""
"[Hòa Giải] Một bên chủ động làm lành và được chấp nhận, hoặc hai bên cùng "
"trải qua sinh tử, hoặc thù hận dần phai nhạt."

msgid "relation_rule_establish_title"
msgstr "[Quy Tắc Thiết Lập Quan Hệ]"

msgid "relation_rule_friend_add"
msgstr ""
"[Thân Thiện] Chỉ cần có bất kỳ tương tác thân thiện thường ngày nào như trò "
"chuyện, song tu, luận bàn, chữa thương... hoặc một lần thể hiện thiện ý là "
"đủ để hình thành quan hệ này, miễn không có xung đột lợi ích thực chất."

msgid "relation_rule_friend_cancel"
msgstr ""
"[Tuyệt Giao] Xảy ra xung đột lợi ích, phản bội, hoặc lâu ngày không qua lại "
"dẫn đến xa cách."

msgid "relation_rule_lovers_add"
msgstr ""
"[Đạo Lữ] Cần là khác giới. Hai bên phải có sự thấu hiểu sâu sắc và tình cảm "
"song phương."

msgid "relation_rule_lovers_cancel"
msgstr "[Chia Tay] Xảy ra mâu thuẫn, tình cảm tan vỡ hoặc bị phản bội nghiêm trọng."

msgid "relation_rule_master_add"
msgstr ""
"[Sư Phụ] Cảnh giới phải cao hơn đồ đệ một khoảng rõ rệt, chẳng hạn Kim Đan "
"so với Luyện Khí."

msgid "relation_rule_master_cancel"
msgstr "[Trục Xuất / Phản Bội] Đồ đệ ngỗ nghịch hoặc sư phụ không còn khả năng truyền dạy."

msgid "relation_rule_sworn_sibling_add"
msgstr ""
"[Kết Nghĩa] Hai bên ý khí tương đồng, từng cùng trải qua sinh tử hoặc biến "
"cố trọng đại."

msgid "relation_rule_sworn_sibling_cancel"
msgstr ""
"[Cắt Nghĩa] Xuất hiện phản bội nghiêm trọng hoặc khác biệt quan niệm sâu sắc "
"đến mức không thể hòa giải."

