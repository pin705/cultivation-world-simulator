# Event Content
msgid ""
"In the auction for {item_name}, {winner_name} outbid {runner_up_name} with "
"{price} spirit stones and won the item."
msgstr ""
"Trong buổi đấu giá {item_name}, {winner_name} đã dùng {price} linh thạch để "
"vượt qua {runner_up_name} và đoạt lấy món vật phẩm này."

msgid "Retreat Bonus"
msgstr "Cảm Ngộ Bế Quan"

# Additional Missing Translations
msgid "Unsupported item type: {item_type}"
msgstr "Loại vật phẩm không được hỗ trợ: {item_type}"

msgid "retreat_action_name"
msgstr "Bế Quan"

msgid "retreat_death_append"
msgstr ""
" Và trong lúc bế quan đã hao cạn tia sinh cơ cuối cùng, tọa hóa mà vong."

msgid "retreat_desc"
msgstr ""
"Bế quan để phá vỡ bản thân, mưu cầu tinh tiến. Hung hiểm vô cùng, không "
"phải người đại nghị lực thì chớ thử."

msgid "retreat_fail"
msgstr ""
"Bế quan thất bại! Nguyên khí tổn thương nặng nề, hao tổn {years} năm thọ "
"nguyên."

msgid "retreat_requirements"
msgstr "Không hạn chế; cần thời gian hồi"

msgid "retreat_start"
msgstr "{avatar} bắt đầu bế quan, ngày phá quan chưa định."

msgid "retreat_story_prompt_fail"
msgstr ""
"Đây là câu chuyện về một lần bế quan thất bại. Hãy miêu tả cách tu sĩ bị "
"tâm ma quấy nhiễu, dấy lên tự nghi ngờ, cuối cùng bị phản phệ trong lúc bế "
"quan. Không cần miêu tả chiến đấu."

msgid "retreat_story_prompt_success"
msgstr ""
"Đây là câu chuyện về một lần bế quan thành công. Hãy miêu tả cách tu sĩ "
"vượt qua cô tịch, cảm ngộ Thiên Đạo và sau cùng đột phá tâm cảnh trong lúc "
"bế quan. Không cần miêu tả chiến đấu."

msgid "retreat_success"
msgstr ""
"Bế quan thành công! Tu vi tinh tiến, cảm ngộ đối với Thiên Đạo cũng càng "
"thêm thâm sâu."

msgid "{avatar_name} abandoned {item_name}."
msgstr "{avatar_name} đã từ bỏ {item_name}."

msgid ""
"{avatar_name} sold newly obtained {item_name}, gained {price} spirit stones."
msgstr ""
"{avatar_name} đã bán {item_name} vừa thu được, kiếm {price} linh thạch."

msgid "game.sect_update_event"
msgstr ""
"Kết toán thường niên của {sect_name}: thu nhập {income} linh thạch, phát "
"bổng lộc {upkeep} linh thạch, số dư {net_change} linh thạch."

msgid "War weariness adjusted to {weariness_after} (active wars: {active_war_count}, yearly recovery: 3, previous: {weariness_before})."
msgstr "Mức chán chiến được điều chỉnh thành {weariness_after} (đang có {active_war_count} cuộc chiến, hồi phục tự nhiên mỗi năm: 3, trước đó là {weariness_before})."

msgid "game.sect_thinking_event"
msgstr "Suy tư của tông môn {sect_name}: {thinking}"

msgid "{winner} won the martial tournament championship and earned {amount} sect contribution for {sect_name}."
msgstr "{winner} đoạt quán quân đại hội luận võ, mang về {amount} điểm cống hiến tông môn cho {sect_name}."

msgid "{teacher_name} taught and guided others at the preaching conference, earning {amount} sect contribution for {sect_name}."
msgstr "{teacher_name} giảng đạo truyền pháp trong đại hội truyền đạo, mang về {amount} điểm cống hiến tông môn cho {sect_name}."

msgid "{winner_name} distinguished themselves in sect war and earned {amount} sect contribution for {sect_name}."
msgstr "{winner_name} lập chiến công trong chiến tranh tông môn và giành được {amount} điểm cống hiến tông môn cho {sect_name}."

msgid "Game automatically saved"
msgstr "Trò chơi đã tự động lưu"

msgid "{avatar_name} made a name in the cultivation world and came to be known as \"{nickname}\"."
msgstr "{avatar_name} đã gây dựng danh tiếng trong tu tiên giới, được người đời gọi là \"{nickname}\"."

msgid "{avatar} self-created technique '{item}'"
msgstr "{avatar} đã tự sáng tạo công pháp \"{item}\"."

msgid "{avatar} self-created weapon '{item}'"
msgstr "{avatar} đã tự sáng tạo binh khí \"{item}\"."

msgid "{avatar} self-created auxiliary equipment '{item}'"
msgstr "{avatar} đã tự sáng tạo trang bị phụ trợ \"{item}\"."

msgid "Equipped newly created {kind} '{item}', sold old equipment '{old_item}' for {refund} spirit stones"
msgstr "Đã trang bị {kind} mới tự sáng tạo là \"{item}\", đồng thời bán trang bị cũ \"{old_item}\" với giá {refund} linh thạch."

msgid "Equipped newly created {kind} '{item}'"
msgstr "Đã trang bị {kind} mới tự sáng tạo là \"{item}\"."
