# Scene Setting
msgid ""
"Event Type: Mysterious Auction\n"
"Scene Setting: The auction takes place in a mysterious space, hosted by a mysterious figure with an unfathomable aura."
msgstr ""
"Loại sự kiện: Đấu giá thần bí\n"
"Bối cảnh: Buổi đấu giá diễn ra trong một không gian huyền bí, do một nhân vật "
"thần bí khí tức sâu không lường nổi chủ trì."

msgid "SECT_10_STYLE"
msgstr ""
"Bề ngoài nhã lệ nhưng trong lòng đầy toan tính, ưa dùng ngôn từ và âm luật "
"để thao túng cục diện, sát phạt mà không dính khói lửa."

msgid "SECT_11_STYLE"
msgstr ""
"Nghiêm cẩn tỉ mỉ, truy cầu cực hạn kỹ nghệ, thiện dùng trận pháp hậu phát "
"chế nhân, từng bước bày cục."

msgid "SECT_12_RANK_ELDER"
msgstr "Các Lão"

msgid "SECT_12_RANK_INNER"
msgstr "Chấp Lệnh"

msgid "SECT_12_RANK_OUTER"
msgstr "Người Gác Đêm"

msgid "SECT_12_RANK_PATRIARCH"
msgstr "Thành Chủ"

msgid "SECT_12_STYLE"
msgstr ""
"Kiên cường bền bỉ, càng trong nghịch cảnh càng vươn lên, hành sự quang minh "
"lỗi lạc mà vẫn thâm mưu viễn lự, cực kỳ che chở người mình."

msgid "SECT_13_STYLE"
msgstr ""
"Giữ nghiêm nguyên tắc, coi trọng đạo nghĩa, luôn xung phong trừ ma vệ đạo, "
"thà gãy chứ không chịu cong."

msgid "SECT_14_STYLE"
msgstr ""
"Mạnh được yếu thua, tùy ý mà làm, tôn sùng tuyệt đối lực lượng và sát lục, "
"coi chúng sinh như huyết thực."

msgid "SECT_1_STYLE"
msgstr ""
"Thần trí thanh minh, tự giữ kỷ luật, lời nói và hành vi nhất trí. Vừa trọng "
"kiếm đạo vừa trọng tâm pháp, chú trọng minh tâm kiến tính."

msgid "SECT_2_RANK_ELDER"
msgstr "Cung Phụng"

msgid "SECT_2_RANK_INNER"
msgstr "Ngự Thú Sư"

msgid "SECT_2_RANK_OUTER"
msgstr "Hộ Tùng"

msgid "SECT_2_RANK_PATRIARCH"
msgstr "Cốc Chủ"

msgid "SECT_2_STYLE"
msgstr ""
"Lời nói trực tiếp, coi trọng sức mạnh cùng huyết tính, sùng thượng săn bắt "
"và bác đấu."

msgid "SECT_3_RANK_ELDER"
msgstr "Chưởng Kính Nhân"

msgid "SECT_3_RANK_INNER"
msgstr "Truyền Nhân"

msgid "SECT_3_RANK_OUTER"
msgstr "Thị Kính"

msgid "SECT_3_RANK_PATRIARCH"
msgstr "Kính Chủ"

msgid "SECT_3_STYLE"
msgstr ""
"Xử sự lãnh tĩnh mà viên dung, ưa lấy nhu thắng cương, giỏi mượn lực và phản "
"chế."

msgid "SECT_4_RANK_ELDER"
msgstr "Phán Quan"

msgid "SECT_4_RANK_INNER"
msgstr "Vô Thường"

msgid "SECT_4_RANK_OUTER"
msgstr "Quỷ Tốt"

msgid "SECT_4_RANK_PATRIARCH"
msgstr "Điện Chủ"

msgid "SECT_4_STYLE"
msgstr ""
"Ngôn từ lạnh lẽo, ít lộ tình cảm, kính sợ nhân quả mà không e ngại sát phạt, "
"thiên về hiệu suất và kết quả."

msgid "SECT_5_RANK_ELDER"
msgstr "Chấp Hình Sứ"

msgid "SECT_5_RANK_INNER"
msgstr "Ảnh Thích"

msgid "SECT_5_RANK_OUTER"
msgstr "Thám Tử"

msgid "SECT_5_RANK_PATRIARCH"
msgstr "Lâu Chủ"

msgid "SECT_5_STYLE"
msgstr ""
"Trực diện dục vọng và cái giá phải trả, không sợ hắc ám, sở trường là công "
"phạt."

msgid "SECT_6_RANK_ELDER"
msgstr "Hộ Pháp"

msgid "SECT_6_RANK_INNER"
msgstr "Mị Tiên"

msgid "SECT_6_RANK_OUTER"
msgstr "Thị Đồng"

msgid "SECT_6_RANK_PATRIARCH"
msgstr "Cung Chủ"

msgid "SECT_6_STYLE"
msgstr ""
"Ngôn từ uyển chuyển, giỏi nắm bắt nhân dục và thế cục, lấy nhu khắc cương."

msgid "SECT_7_RANK_ELDER"
msgstr "Thủ Tọa"

msgid "SECT_7_RANK_INNER"
msgstr "Hành Giả"

msgid "SECT_7_RANK_OUTER"
msgstr "Cư Sĩ"

msgid "SECT_7_RANK_PATRIARCH"
msgstr "Trụ Trì"

msgid "SECT_7_STYLE"
msgstr ""
"Trang nghiêm trầm ổn, coi trọng an hồn trấn tà, ít lời mà quả quyết."

msgid "SECT_8_RANK_ELDER"
msgstr "Hộ Pháp"

msgid "SECT_8_RANK_INNER"
msgstr "Ảnh Vệ"

msgid "SECT_8_RANK_OUTER"
msgstr "Thám Tử"

msgid "SECT_8_RANK_PATRIARCH"
msgstr "Môn Chủ"

msgid "SECT_8_STYLE"
msgstr ""
"Hành sự bí mật và quyết đoán, trọng kết quả hơn hư danh, giỏi tiềm hành và "
"xuất kỳ bất ý."

msgid "SECT_9_RANK_ELDER"
msgstr "Đại Cung Phụng"

msgid "SECT_9_RANK_INNER"
msgstr "Chấp Sự"

msgid "SECT_9_RANK_OUTER"
msgstr "Học Đồ"

msgid "SECT_9_RANK_PATRIARCH"
msgstr "Thành Chủ"

msgid "SECT_9_STYLE"
msgstr ""
"Thực tế tinh minh, coi trọng giao dịch và tín dự, đề cao quy củ cùng trật "
"tự."

msgid "elder"
msgstr "Trưởng Lão"

msgid "inner_disciple"
msgstr "Nội Môn Đệ Tử"

msgid "outer_disciple"
msgstr "Ngoại Môn Đệ Tử"

msgid "World lore and history"
msgstr "Thế giới quan và lịch sử"
