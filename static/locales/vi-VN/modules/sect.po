# Sect Rank
msgid "patriarch"
msgstr "Chưởng Môn"

msgid "phenomenon_change"
msgstr ""
"{old_name} tan biến, thiên địa dị tượng lại hiện! {new_name}: {new_desc}."

msgid "world_creation_phenomenon"
msgstr "Thế giới sơ khai, thiên giáng dị tượng! {name}: {desc}."

msgid ""
"{avatar_name} deliberated and redefined their long-term objective: "
"{objective}"
msgstr ""
"{avatar_name} sau một phen suy nghĩ, đã xác lập lại chí hướng lâu dài: "
"{objective}"

msgid "{avatar_name} determined their long-term objective: {objective}"
msgstr "{avatar_name} đã xác lập chí hướng lâu dài của mình: {objective}"

# Sect System - Sects
msgid "Base effect"
msgstr "Hiệu Quả Cơ Bản"

msgid "Sect random event"
msgstr "Biến Cố Tông Môn"

msgid "Temporary effect"
msgstr "Hiệu Quả Tạm Thời"

msgid "{sect_name} (Alignment: {alignment}, Headquarters: {hq_name})"
msgstr "{sect_name} (Trận doanh: {alignment}, Trú địa: {hq_name})"

msgid ""
"{sect_name} (Alignment: {alignment}, Style: {style}, Headquarters: "
"{hq_name}){effect}"
msgstr ""
"{sect_name} (Trận doanh: {alignment}, Phong cách: {style}, Trú địa: "
"{hq_name}){effect}"

msgid ""
"{sect_name} (Orthodoxy: {orthodoxy}, Alignment: {alignment}, Headquarters: "
"{hq_name})"
msgstr ""
"{sect_name} (Đạo thống: {orthodoxy}, Trận doanh: {alignment}, Trú địa: "
"{hq_name})"

msgid ""
"{sect_name} (Orthodoxy: {orthodoxy}, Alignment: {alignment}, Style: {style},"
" Headquarters: {hq_name}){effect}"
msgstr ""
"{sect_name} (Đạo thống: {orthodoxy}, Trận doanh: {alignment}, Phong cách: "
"{style}, Trú địa: {hq_name}){effect}"

msgid "Our sect has settled its priorities for the coming years; next we should guard our rules and foundations, recruit talent with care, reward and punish fairly, and expand our momentum through steady progress."
msgstr "Bổn môn đã định rõ trọng tâm cho những năm tới; tiếp theo cần giữ vững môn quy và nền móng, chiêu nạp nhân tài thận trọng, thưởng phạt phân minh, và mở rộng khí thế bằng từng bước tiến vững chắc."

msgid "There is currently no celestial phenomenon."
msgstr "Hiện tại không có thiên địa dị tượng."

msgid "A celestial phenomenon is present, but its description is missing."
msgstr "Hiện đang có thiên địa dị tượng, nhưng phần mô tả còn thiếu."

msgid "New disciples must abide by the sect rules."
msgstr "Đệ tử mới nhập môn phải tuân thủ môn quy."

msgid "{sect_name} has extended a recruitment invitation to you."
msgstr "{sect_name} đã gửi lời chiêu mộ đến ngươi."

msgid "Sect overview: {sect_info}"
msgstr "Khái quát tông môn: {sect_info}"

msgid "Sect rules: {rule_desc}"
msgstr "Môn quy: {rule_desc}"

msgid "If you accept, you will become a disciple of this sect."
msgstr "Nếu chấp thuận, ngươi sẽ trở thành đệ tử của tông môn này."

msgid "Accept invitation"
msgstr "Chấp nhận chiêu mộ"

msgid "Join {sect_name} and become one of its disciples."
msgstr "Gia nhập {sect_name} và trở thành môn hạ đệ tử."

msgid "Decline invitation"
msgstr "Từ chối chiêu mộ"

msgid "Remain an independent cultivator."
msgstr "Tiếp tục giữ thân phận tán tu."

msgid "{avatar_name} accepted {sect_name}'s invitation."
msgstr "{avatar_name} đã chấp nhận lời chiêu mộ của {sect_name}."

msgid "{avatar_name} declined {sect_name}'s invitation."
msgstr "{avatar_name} đã từ chối lời chiêu mộ của {sect_name}."

msgid "{sect_name} declared war on {target_name}; from this point on, the two sects are at war."
msgstr "{sect_name} đã tuyên chiến với {target_name}; từ đây hai tông chính thức bước vào chiến tranh."

msgid "{sect_name} made peace with {target_name}, and the state of war between them came to an end."
msgstr "{sect_name} đã nghị hòa với {target_name}, trạng thái chiến tranh giữa hai bên chấm dứt."

msgid "{sect_name} spent {cost} spirit stones to recruit {avatar_name}; {avatar_name} officially became a disciple of the sect."
msgstr "{sect_name} đã chi {cost} linh thạch để chiêu nạp {avatar_name}; {avatar_name} chính thức trở thành đệ tử của bổn tông."

msgid "{sect_name} judged that {avatar_name} had gravely violated the sect rules and expelled them from the sect."
msgstr "{sect_name} phán định {avatar_name} đã nghiêm trọng vi phạm môn quy và trục xuất khỏi tông môn."

msgid "{sect_name} bestowed the technique \"{technique_name}\" upon {avatar_name}."
msgstr "{sect_name} đã ban công pháp \"{technique_name}\" cho {avatar_name}."

msgid "{sect_name} granted {amount} spirit stones to {avatar_name} in support of their cultivation."
msgstr "{sect_name} đã cấp {amount} linh thạch cho {avatar_name} để trợ giúp tu hành."

msgid "recruited {count} rogue cultivators"
msgstr "chiêu nạp {count} tán tu"

msgid "declared war {count} times"
msgstr "tuyên chiến {count} lần"

msgid "made peace {count} times"
msgstr "nghị hòa {count} lần"

msgid "expelled {count} members"
msgstr "trục xuất {count} môn nhân"

msgid "bestowed techniques {count} times"
msgstr "ban công pháp {count} lần"

msgid "granted spirit-stone support {count} times"
msgstr "cấp linh thạch hỗ trợ {count} lần"

msgid "{sect_name} focused this round of sect decisions on consolidation and observation, with no major adjustments made."
msgstr "{sect_name} trong đợt quyết sách này chủ yếu quan sát và củng cố, không đưa ra điều chỉnh lớn."

msgid "{sect_name} this round of sect decisions:"
msgstr "Quyết sách tông môn vòng này của {sect_name}:"

msgid "Every successful recruit immediately costs {recruit_cost} spirit stones and increases future yearly member upkeep."
msgstr "Mỗi lần chiêu mộ thành công sẽ lập tức tiêu tốn {recruit_cost} linh thạch và làm tăng chi phí nuôi dưỡng môn nhân cho các năm sau."

msgid "Each support action always costs {support_amount} spirit stones."
msgstr "Mỗi lần hỗ trợ luôn tiêu tốn cố định {support_amount} linh thạch."

msgid "Granting techniques does not directly spend spirit stones, but it consumes sect inheritance resources; frequent rewards reduce the value and rarity of the sect's scripture collection."
msgstr "Ban công pháp không trực tiếp tiêu linh thạch, nhưng sẽ tiêu hao tài nguyên truyền thừa của tông môn; ban thưởng quá thường xuyên sẽ làm giảm giá trị và độ quý hiếm của tàng kinh các."

msgid "[{month_stamp}] {content}"
msgstr "[{month_stamp}] {content}"
