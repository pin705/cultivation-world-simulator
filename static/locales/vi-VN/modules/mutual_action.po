msgid ", sell old {label}『{old_name}』"
msgstr ", bán {label} cũ『{old_name}』"

msgid ", {replace} old {label}『{old_name}』"
msgstr ", {replace} {label} cũ『{old_name}』"

msgid "Already lovers"
msgstr "Đã là đạo lữ"

msgid "Already sworn siblings"
msgstr "Đã là huynh đệ/tỷ muội kết nghĩa"

# MutualAction: Confess
msgid "confess_action_name"
msgstr "Tỏ tình"

msgid "confess_description"
msgstr ""
"Tỏ bày tình ý với tu sĩ ở trong phạm vi tương tác. Nếu đối phương chấp nhận, "
"hai người sẽ kết thành đạo lữ."

msgid "confess_requirements"
msgstr "Mục tiêu ở trong phạm vi tương tác, và hiện chưa phải đạo lữ."

msgid "confess_story_prompt"
msgstr ""
"Hãy miêu tả quá trình {initiator} tỏ tình với {target}, bao gồm rung động "
"trong lòng và bầu không khí xung quanh. Nếu được chấp nhận, hãy khắc họa sự "
"lãng mạn khi đôi bên kết thành đạo lữ. Nếu bị từ chối, hãy miêu tả sự khước "
"từ nhẹ nhàng cùng nỗi tiếc nuối."

# MutualAction: Conversation
msgid "conversation_action_name"
msgstr "Trò chuyện"

msgid "conversation_description"
msgstr "Cùng đối phương tiến hành một đoạn trao đổi đối thoại"

msgid "conversation_requirements"
msgstr "Mục tiêu ở trong phạm vi tương tác"

# MutualAction: DriveAway
msgid "drive_away_action_name"
msgstr "Xua đuổi"

msgid "drive_away_description"
msgstr "Dùng vũ lực uy hiếp đối phương rời khỏi nơi này"

msgid "drive_away_requirements"
msgstr "Mục tiêu ở trong phạm vi tương tác; không thể liên tục chấp hành"

msgid "feedback_talk"
msgstr "Nhận lời trò chuyện"

msgid "feedback_yield"
msgstr "Nhượng bộ"

# MutualAction: Gift
msgid "gift_action_name"
msgstr "Tặng vật"

msgid "gift_description"
msgstr ""
"Tặng linh thạch hoặc vật phẩm cho đối phương. Tham số 'item_id' hãy điền ID "
"vật phẩm (số nguyên) hoặc 'SPIRIT_STONE' (linh thạch)."

msgid "gift_requirements"
msgstr ""
"Người khởi xướng phải sở hữu vật phẩm; mục tiêu ở trong phạm vi tương tác; "
"đan dược không thể đem tặng"

# MutualAction: Impart
msgid "impart_action_name"
msgstr "Truyền đạo"

msgid "impart_description"
msgstr ""
"Truyền thụ kinh nghiệm tu luyện cho đệ tử, đồ tôn, đồng môn, con cái, cháu "
"chắt hoặc bằng hữu của ngươi"

msgid "impart_requirements"
msgstr ""
"Mục tiêu phải là đệ tử, đồ tôn, đồng môn, con cái, cháu chắt hoặc bằng hữu "
"của người khởi xướng; cấp độ người khởi xướng > cấp độ mục tiêu + 20; mục "
"tiêu ở trong phạm vi tương tác; không thể liên tục chấp hành"

# MutualAction Base
msgid "mutual_action_name"
msgstr "Hành động tương tác"

msgid "mutual_action_requirements"
msgstr "Mục tiêu ở trong phạm vi tương tác"

# MutualAction: Attack
msgid "mutual_attack_action_name"
msgstr "Tấn công"

msgid "mutual_attack_description"
msgstr "Tiến hành công kích mục tiêu"

msgid "mutual_attack_requirements"
msgstr "Mục tiêu ở trong phạm vi tương tác; không thể liên tục chấp hành"

# MutualAction: Occupy
msgid "occupy_action_name"
msgstr "Cướp đoạt động phủ"

msgid "occupy_description"
msgstr ""
"Chiếm lấy hoặc cướp đoạt động phủ. Lưu ý: điều này có thể dẫn tới chiến đấu "
"với chủ nhân của động phủ"

msgid "occupy_requirements"
msgstr "Mục tiêu ở trong phạm vi tương tác; không thể liên tục chấp hành"

msgid "occupy_story_prompt"
msgstr ""
"Đây là một trận chiến tranh đoạt động phủ. Không được nhắc tới con số HP hay "
"thương hại cụ thể."

# MutualAction: Spar
msgid "spar_action_name"
msgstr "Tỷ thí"

msgid "spar_description"
msgstr ""
"Tỷ thí với mục tiêu, dừng lại đúng lúc (tăng mạnh độ thuần thục binh khí, "
"không gây thương tổn)"

msgid "spar_requirements"
msgstr "Mục tiêu ở trong phạm vi tương tác; không thể liên tục chấp hành"

msgid "spar_story_prompt"
msgstr ""
"Đây là màn tỷ thí hữu hảo giữa hai người, điểm tới là dừng, không có thương "
"tổn thật sự. Hãy tập trung miêu tả chiêu thức tinh diệu của đôi bên và sự "
"gợi mở lẫn nhau. Không được xuất hiện cảnh máu me hay trọng thương."

msgid "spirit stones"
msgstr "linh thạch"

msgid "swear_brotherhood_action_name"
msgstr "Kết nghĩa"

msgid "swear_brotherhood_description"
msgstr ""
"Đề nghị cùng một tu sĩ trong phạm vi tương tác kết thành nghĩa huynh đệ/tỷ "
"muội."

msgid "swear_brotherhood_requirements"
msgstr "Mục tiêu ở trong phạm vi tương tác; hiện chưa phải huynh đệ/tỷ muội kết nghĩa."

msgid "swear_brotherhood_story_prompt"
msgstr ""
"Đây là một màn kết nghĩa hào khí ngất trời. Hãy miêu tả sự đồng điệu ý chí "
"giữa hai người cùng lời thề đồng sinh cộng tử."

# MutualAction: Talk
msgid "talk_action_name"
msgstr "Bắt chuyện"

msgid "talk_description"
msgstr "Chủ động bắt chuyện với một người khác, không thể chọn chính mình"

msgid "talk_requirements"
msgstr "Mục tiêu ở trong phạm vi tương tác"

msgid "{avatar1} conversation with {avatar2}: {content}"
msgstr "{avatar1} trò chuyện cùng {avatar2}: {content}"

msgid "{giver} imparts cultivation knowledge to {receiver}"
msgstr "{giver} truyền thụ tri thức tu luyện cho {receiver}"

msgid ""
"{initiator} attempted to seize {target}'s cave dwelling {region}, {target} "
"rejected and engaged in battle"
msgstr ""
"{initiator} mưu toan cướp đoạt động phủ {region} của {target}, nhưng {target} "
"đã cự tuyệt và nghênh chiến"

msgid "{initiator} attempts to gift {item} to {target}"
msgstr "{initiator} định tặng {item} cho {target}"

msgid "{initiator} attempts to seize {region} from {host}"
msgstr "{initiator} định cướp đoạt {region} từ tay {host}"

msgid "{initiator} and {target} enjoyed a tea gathering"
msgstr "{initiator} và {target} cùng dự một buổi trà đàm vui vẻ"

msgid "{initiator} and {target} played a game of chess"
msgstr "{initiator} và {target} đã đối một ván cờ"

msgid "{initiator} challenges {target} to spar"
msgstr "{initiator} khiêu chiến {target} tiến hành tỷ thí"

msgid "{initiator} confesses their love to {target}"
msgstr "{initiator} thổ lộ tình ý với {target}"

msgid "{initiator} forced {target} to yield {region}"
msgstr "{initiator} ép {target} nhường lại {region}"

msgid "{initiator} initiates {action} with {target}"
msgstr "{initiator} chủ động {action} với {target}"

msgid "{initiator} proposes to become sworn siblings with {target}"
msgstr "{initiator} đề nghị cùng {target} kết thành nghĩa huynh đệ/tỷ muội"

msgid "{initiator} successfully gifted {item} to {target}"
msgstr "{initiator} đã tặng thành công {item} cho {target}"

msgid "{master} imparts cultivation knowledge to apprentice {apprentice}"
msgstr "{master} truyền thụ tri thức tu luyện cho đệ tử {apprentice}"

msgid "{region} is not a cultivation area, cannot occupy"
msgstr "{region} không phải khu vực tu luyện, không thể chiếm giữ"

msgid "{target} accepted {initiator}'s confession, they became lovers"
msgstr "{target} chấp nhận lời tỏ tình của {initiator}, hai người kết thành đạo lữ"

msgid "{target} accepted {initiator}'s proposal, they became sworn siblings"
msgstr "{target} chấp nhận lời đề nghị của {initiator}, hai người kết thành nghĩa huynh đệ/tỷ muội"

msgid "{target} accepted {initiator}'s talk invitation"
msgstr "{target} chấp nhận lời mời bắt chuyện của {initiator}"

msgid "{target} feedback to {initiator}: {feedback}"
msgstr "{target} hồi đáp với {initiator}: {feedback}"

msgid "{target} rejected {initiator}'s confession"
msgstr "{target} đã từ chối lời tỏ tình của {initiator}"

msgid "{target} rejected {initiator}'s proposal to become sworn siblings"
msgstr "{target} từ chối lời đề nghị kết nghĩa của {initiator}"

msgid "{target} rejected {initiator}'s talk invitation"
msgstr "{target} từ chối lời mời bắt chuyện của {initiator}"

msgid "{target} rejected {initiator}'s gift: {item}"
msgstr "{target} đã từ chối quà tặng của {initiator}: {item}"

msgid ""
"{winner} gained slight advantage in sparring, defeated {loser}. ({winner} "
"proficiency +{w_gain}, {loser} proficiency +{l_gain})"
msgstr ""
"{winner} trong lúc tỷ thí đã nhỉnh hơn một bậc, đánh bại {loser}. (Độ thuần "
"thục của {winner} +{w_gain}, độ thuần thục của {loser} +{l_gain})"
