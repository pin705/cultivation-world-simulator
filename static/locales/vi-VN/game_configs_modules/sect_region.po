#. sect_region.csv: SECT_REGION_401_DESC
msgid "SECT_REGION_401_DESC"
msgstr ""
"Quần phong Tuyệt Vân đâm thẳng vào biển mây, các ngọn núi nối với nhau bằng "
"xích sắt và vân kiều, đường núi hiểm trở đến mức chỉ những ai thật sự ổn "
"định được kiếm ý mới có thể bước lên tầng cao hơn. Lưng chừng núi có thể "
"thấy thí kiếm đài, tẩy kiếm trì và từng mảng vách đá chằng chịt kiếm ngân; "
"càng lên gần đỉnh, tiếng gió càng sắc, thỉnh thoảng còn có lôi quang xẹt "
"ngang sườn núi. Cả sơn môn giống như một thanh cổ kiếm đã rút khỏi vỏ mà "
"chưa từng quay về, thanh hàn và đầy phong mang."

#. sect_region.csv: SECT_REGION_401_NAME
msgid "SECT_REGION_401_NAME"
msgstr "Tuyệt Vân Phong"

#. sect_region.csv: SECT_REGION_402_DESC
msgid "SECT_REGION_402_DESC"
msgstr ""
"Vạn Thú Quật ẩn sâu trong bụng núi, bên ngoài bị chướng khí và dây leo phong"
" kín như một tấm lá chắn tự nhiên. Chỉ khi tiến sâu vào trong mới thấy được "
"các tầng động thiên thú vực đang dần chìm xuống. Từng tầng động được ngăn "
"bằng thạch kiều, thiết áp và ngự thú đài, còn tiếng thú gầm trầm thấp cùng "
"âm thanh xích sắt va chạm thì vang dội suốt ngày đêm. Xương vụn, dấu vuốt và"
" yêu khí chưa tan rải đầy mặt đất. Nơi này không giống sơn môn bình thường, "
"mà giống một thành sào huyệt của cự thú đang sống."

#. sect_region.csv: SECT_REGION_402_NAME
msgid "SECT_REGION_402_NAME"
msgstr "Vạn Thú Quật"

#. sect_region.csv: SECT_REGION_403_DESC
msgid "SECT_REGION_403_DESC"
msgstr ""
"Tĩnh Hải Nhai treo mình trên vách biển cao vạn trượng, nơi điện các, hành "
"lang và đài quan triều bằng hàn băng linh ngọc nửa ẩn nửa hiện giữa màn "
"sương biển. Từ xa nhìn lại, cả sơn môn như đang lơ lửng trong tiếng sóng và "
"ánh trăng. Ngọc bích bên bờ vực phản chiếu tinh quang cùng biển trời, còn "
"mỗi lần thủy triều lên xuống, tường và mặt đất lại nổi lên quầng sáng như "
"gợn nước khiến đường đi trở nên hư thực khó phân. Nơi đây yên tĩnh đến mức "
"gần như trống không, chỉ còn tiếng sóng, tiếng gió và tiếng chuông lướt qua "
"mái hiên nhắc người ta rằng mình vẫn còn ở nhân gian."

#. sect_region.csv: SECT_REGION_403_NAME
msgid "SECT_REGION_403_NAME"
msgstr "Tĩnh Hải Nhai"

#. sect_region.csv: SECT_REGION_404_DESC
msgid "SECT_REGION_404_DESC"
msgstr ""
"Tử Tịch Hải được tạo thành từ những hòn đảo đen và các vịnh triều ngầm, nối "
"với nhau bằng cầu ván hẹp, bến đá tàn bia và hải đăng ma hỏa, nhìn từ xa như"
" một quỷ thành trôi trên mặt biển mực đen. Mặt nước quanh năm vô phong mà "
"vẫn nổi sóng, mỗi con triều dựng lên lại kèm theo âm thanh rít gào như tiếng"
" khóc xa xăm. Điện vũ và bậc đá trên đảo bị sương ẩm nhuộm thành màu xám "
"trắng lẫn u thanh. Ban đêm, thứ nổi bật nhất không phải ánh trăng mà là từng"
" ngọn dẫn hồn đăng chập chờn trong sương biển."

#. sect_region.csv: SECT_REGION_404_NAME
msgid "SECT_REGION_404_NAME"
msgstr "Tử Tịch Hải"

#. sect_region.csv: SECT_REGION_405_DESC
msgid "SECT_REGION_405_DESC"
msgstr ""
"Thoạt nhìn, Thiên Cơ Cốc chỉ như một sơn cốc bình thường với đường đá xanh, "
"phi diêm lầu các và đình viện hoa cỏ được bài trí rất tinh xảo. Nhưng đến "
"gần mới nhận ra cầu có thể tự đổi hướng, tường có thể mở khép, ngay cả bậc "
"thang lên xuống cũng ẩn cơ quát. Trên cao là vọng lâu và huyền kiều, dưới "
"thấp là ám đạo, công phường và mật thất, thỉnh thoảng còn vang lên tiếng "
"răng truyền ăn khớp, kim loại rung nhẹ hoặc bước chân mộc ngẫu từ nơi vô "
"định. Điều đáng sợ nhất ở đây không phải một bẫy nào đó, mà là cả sơn cốc "
"chính là một cỗ cơ quan khổng lồ."

#. sect_region.csv: SECT_REGION_405_NAME
msgid "SECT_REGION_405_NAME"
msgstr "Thiên Cơ Cốc"

#. sect_region.csv: SECT_REGION_406_DESC
msgid "SECT_REGION_406_DESC"
msgstr ""
"Tiêu Kim Quật ẩn trong một động thiên riêng phía sau khu phố phồn hoa, cửa "
"vào là biển đèn, hương sương, khúc kiều và từng lớp lầu các thủy tạ chồng "
"lên nhau. Càng đi sâu, tiếng náo nhiệt càng lùi lại, nhường chỗ cho tiếng "
"nước và nhạc âm dai dẳng quấn người. Tầng ngoài rực vàng ngọc, khách khứa "
"như mắc cửi; bên trong lại có tĩnh thất, ôn tuyền và Huyễn Mộng Trì được "
"ngăn bởi lụa mỏng, hoa tường và mây khói, đến cả con đường cũng như cố ý "
"khiến người ta lạc lối. Đẹp đẽ, xa hoa là thế, nhưng khó ai nói rõ mình đang"
" dự yến, nhập mộng hay bước vào một loại tu hành khác."

#. sect_region.csv: SECT_REGION_406_NAME
msgid "SECT_REGION_406_NAME"
msgstr "Tiêu Kim Quật"

#. sect_region.csv: SECT_REGION_407_DESC
msgid "SECT_REGION_407_DESC"
msgstr ""
"Phổ Độ Đảo cô treo giữa Phong Bạo Hải, bên ngoài là sóng dữ ngập trời và "
"điện quang cuồn cuộn, còn bên trong lại bị tiếng chuông cùng phật quang ép "
"thành một vùng tĩnh mịch gần như đông cứng. Kim Cang Tháp đứng giữa đảo, "
"xung quanh là phật điện, bậc đá, đài khổ tu trên vách biển và bến giáp biển."
" Kim linh trên đỉnh tháp rung dài theo gió biển, dường như có thể xoa dịu "
"cơn bão từng chút một. Mỗi khi sương sớm tan đi, kim quang rắc lên đá ngầm "
"đen cùng điện các xanh trắng, cả hòn đảo trông như một pháp ấn trấn tà nổi "
"lên từ biển giận."

#. sect_region.csv: SECT_REGION_407_NAME
msgid "SECT_REGION_407_NAME"
msgstr "Phổ Độ Đảo"

#. sect_region.csv: SECT_REGION_408_DESC
msgid "SECT_REGION_408_DESC"
msgstr ""
"Ám Ảnh Chiểu Trạch quanh năm không thấy thiên quang, độc vụ, nước thối và cổ"
" mộc quấn rễ bịt kín toàn bộ địa vực. Người ngoài thường chưa kịp nhìn thấy "
"sơn môn đã bị những bóng tối vô hình dõi theo. Căn cứ thật sự không tập "
"trung trên mặt đất: giữa tán cây ẩn giấu lâu các và cầu treo, còn dưới bùn "
"lầy lại là mật đạo, ám thất và những lối vào bị chướng khí che khuất. Nơi "
"đây gần như không có tầm nhìn thoáng đãng hoàn chỉnh nào, chỉ có đăng quang "
"lạnh chập chờn, sương mù trôi dạt và dòng hắc thủy có thể nuốt mất tiếng "
"bước chân bất cứ lúc nào."

#. sect_region.csv: SECT_REGION_408_NAME
msgid "SECT_REGION_408_NAME"
msgstr "Ám Ảnh Chiểu Trạch"

#. sect_region.csv: SECT_REGION_409_DESC
msgid "SECT_REGION_409_DESC"
msgstr ""
"Đa Bảo Phù Không Đảo không phải một hòn đảo đơn lẻ mà là cả quần đảo lơ lửng"
" với kích cỡ khác nhau, nối với nhau bằng cự liên, vân kiều và hàng tuyến "
"của phi chu, hợp thành một tòa tiên thành treo giữa trời cao. Vòng ngoài là "
"vân chu cảng và bãi hàng luôn tấp nập, tầng giữa là phố buôn, lâu đấu giá và"
" phường thị, còn nơi cao nhất dựng đầy luyện khí cao tháp phun lò hỏa suốt "
"ngày đêm. Khi màn đêm buông xuống, ánh đèn chạy dọc theo xích sắt và không "
"kiều tới tận tầng mây, khiến cả vùng đất này giống như một mạng lưới thương "
"nghiệp bằng vàng trải khắp bầu trời."

#. sect_region.csv: SECT_REGION_409_NAME
msgid "SECT_REGION_409_NAME"
msgstr "Đa Bảo Phù Không Đảo"

#. sect_region.csv: SECT_REGION_410_DESC
msgid "SECT_REGION_410_DESC"
msgstr ""
"Hồi Âm Cốc bị hai vách núi cao ép hẹp vào trong, tự nhiên hình thành vô số "
"lỗ hồi hưởng và khe cộng chấn, khiến chỉ một tiếng gảy đàn thôi cũng có thể "
"xoáy chuyển rất lâu không dứt. Trong cốc, đình đài, thủy tạ, cầm lâu và hành"
" lang bày theo thế núi, còn suối thì xuyên qua lầu mà chảy. Bề ngoài nơi đây"
" tao nhã như tiên gia biệt uyển, nhưng nếu lắng nghe kỹ sẽ thấy gió lướt qua"
" mái hiên hay giọt nước rơi xuống đầm đều như đã bị một bàn tay vô hình sắp "
"xếp lại tiết tấu. Nguy hiểm nhất ở đây thường là lúc cả cốc bỗng im lặng "
"hẳn."

#. sect_region.csv: SECT_REGION_410_NAME
msgid "SECT_REGION_410_NAME"
msgstr "Hồi Âm Cốc"

#. sect_region.csv: SECT_REGION_411_DESC
msgid "SECT_REGION_411_DESC"
msgstr ""
"Mê Tung Thiên bề ngoài chỉ là một cô phong, nhưng khi thật sự bước vào sơn "
"môn mới phát hiện đình đài, bậc đá, huyền kiều và sơn đạo đều được cài trong"
" từng tầng không gian gấp lớp. Cùng một con đường mà nhìn từ trước và sau có"
" thể hoàn toàn khác nhau. Trên sườn núi có quảng trường khắc đầy trận văn, "
"hành lang nổi giữa không trung và các lầu các lúc ẩn lúc hiện, còn dưới chân"
" thì thỉnh thoảng lóe lên những đường sáng như thể cả ngọn núi đang chậm rãi"
" suy nghĩ. Ở đây chẳng có phương hướng nào thật sự ổn định; mỗi bước đi đều "
"như tiến vào một tầng thiên địa khác."

#. sect_region.csv: SECT_REGION_411_NAME
msgid "SECT_REGION_411_NAME"
msgstr "Mê Tung Thiên"

#. sect_region.csv: SECT_REGION_412_DESC
msgid "SECT_REGION_412_DESC"
msgstr ""
"Cực Quang Thiên Cảnh nằm sâu trong vùng cực bắc vĩnh dạ, bên ngoài là băng "
"nguyên dài dằng dặc và im lìm, chỉ riêng cung thành này quanh năm được cực "
"quang lưu động chiếu sáng như ban ngày. Tường băng cao lớn, huyền thiết cung"
" môn, băng kiều và giáo trường đều phản chiếu hàn quang lạnh lẽo dưới màn "
"sáng, còn sâu trong thành, Thánh Hỏa Đàn lại nhuộm cả vùng lạnh giá thành "
"một màu đỏ ấm không bao giờ tắt. Vẻ động lòng nhất của nơi đây không chỉ là "
"tráng lệ, mà là trật tự trong đó băng và hỏa, tĩnh và minh cùng tồn tại."

#. sect_region.csv: SECT_REGION_412_NAME
msgid "SECT_REGION_412_NAME"
msgstr "Cực Quang Thiên Cảnh"

#. sect_region.csv: SECT_REGION_413_DESC
msgid "SECT_REGION_413_DESC"
msgstr ""
"Thánh Hiền Lâm nằm ở nơi linh mạch giao hội giữa trung vực, cổ mộc vươn "
"trời, bia lâm phân tán, còn giảng đường, thư các và tiểu viện bên nước thì "
"ẩn hiện dưới bóng cây. Người đi qua đây thường phải bước trên thạch kính phủ"
" lá rụng và xuyên qua hành lang khắc đầy cổ văn. Ban ngày, tiếng đọc sách "
"theo gió rừng truyền đi rất xa; ban đêm, bia văn lại phát ra ánh sáng yếu "
"dưới trăng, khiến bóng cây và mái hiên càng thêm tĩnh mặc. Nơi này không "
"giống một sơn môn khép kín, mà giống một học cung đang tiếp tục lớn lên cùng"
" thời gian."

#. sect_region.csv: SECT_REGION_413_NAME
msgid "SECT_REGION_413_NAME"
msgstr "Thánh Hiền Lâm"

#. sect_region.csv: SECT_REGION_414_DESC
msgid "SECT_REGION_414_DESC"
msgstr ""
"Ngọn núi nơi Tu La Huyết Trì tọa lạc mang màu đỏ thẫm từ trong ra ngoài, "
"những khe đá luôn trào lên huyết vụ cùng nhiệt lưu, còn sâu trong lòng núi "
"thì bị khoét thành huyết trì ngầm khổng lồ và các điện vũ tế trường chồng "
"lớp lên nhau. Thiết tác kiều bắc ngang huyết hà, bậc đá dẫn thẳng xuống "
"chiến đài, cốt quật và tế đàn đang rực sáng trong xích quang. Càng đi sâu "
"xuống lòng đất, mùi sắt gỉ, dược khí và huyết tinh ẩm ướt càng nặng. Toàn bộ"
" nơi này giống như một con hung thú đang chậm rãi hô hấp dưới mặt đất."

#. sect_region.csv: SECT_REGION_414_NAME
msgid "SECT_REGION_414_NAME"
msgstr "Tu La Huyết Trì"
