#. normal_region.csv: 位于大陆中部，地势平坦，灵气平和。是初学...
msgid "NORMAL_REGION_101_DESC"
msgstr ""
"Nằm ở trung tâm đại lục, địa thế bằng phẳng, linh khí ôn hòa. Đây là nơi lý "
"tưởng để người mới nhập đạo đặt nền móng và khai tông lập phái."

#. normal_region.csv: 平原地带
msgid "NORMAL_REGION_101_NAME"
msgstr "Bình Nguyên Địa Đới"

#. normal_region.csv: 位于大陆极西，茫茫大漠，黄沙漫天。此地气...
msgid "NORMAL_REGION_102_DESC"
msgstr ""
"Nằm ở cực tây đại lục, hoang mạc mênh mang, hoàng sa đầy trời. Khí hậu nơi "
"đây khô hạn, chênh lệch nhiệt độ ngày đêm cực lớn, là con đường bắt buộc của "
"các thương đội xuyên sa mạc."

#. normal_region.csv: 西域流沙
msgid "NORMAL_REGION_102_NAME"
msgstr "Tây Vực Lưu Sa"

#. normal_region.csv: 位于大陆西南，古木参天，藤蔓缠绕。此地森...
msgid "NORMAL_REGION_103_DESC"
msgstr ""
"Nằm ở tây nam đại lục, cổ mộc cao vút tận trời, dây leo chằng chịt. Rừng sâu "
"rậm rạp, dã thú đông đúc, là vùng hiểm địa để hái thuốc và săn bắn."

#. normal_region.csv: 南疆蛮荒
msgid "NORMAL_REGION_103_NAME"
msgstr "Nam Cương Man Hoang"

#. normal_region.csv: 位于大陆极北，千里冰封，万年不化。此地严...
msgid "NORMAL_REGION_104_DESC"
msgstr ""
"Nằm ở cực bắc đại lục, ngàn dặm băng phong, vạn năm không tan. Nơi đây giá "
"lạnh thấu xương, gió tuyết dữ dội, chỉ những kẻ mạo hiểm có ý chí cứng cỏi "
"nhất mới có thể sống sót."

#. normal_region.csv: 极北冰原
msgid "NORMAL_REGION_104_NAME"
msgstr "Cực Bắc Băng Nguyên"

#. normal_region.csv: 位于大陆极东，浩瀚无垠，波涛汹涌。此地风...
msgid "NORMAL_REGION_105_DESC"
msgstr ""
"Nằm ở cực đông đại lục, biển rộng vô ngần, sóng dữ ngút trời. Gió lớn sóng "
"to, ám tiêu khắp chốn, là vùng hải vực đầy thách thức đối với thương nhân "
"hàng hải và ngư dân."

#. normal_region.csv: 无边碧海
msgid "NORMAL_REGION_105_NAME"
msgstr "Vô Biên Bích Hải"

#. normal_region.csv: 横贯大陆东西，一江春水向东流，奔腾不息入...
msgid "NORMAL_REGION_106_DESC"
msgstr ""
"Con sông lớn cắt ngang đại lục từ tây sang đông, một dải xuân thủy cuồn cuộn "
"chảy mãi về phía Đông Hải. Dòng nước xiết không ngừng, là tuyến giao thông "
"thủy quan trọng bậc nhất."

#. normal_region.csv: 天河奔流
msgid "NORMAL_REGION_106_NAME"
msgstr "Thiên Hà Bôn Lưu"

#. normal_region.csv: 位于大陆东部，连绵起伏，直插云霄。此地山...
msgid "NORMAL_REGION_107_DESC"
msgstr ""
"Nằm ở phía đông đại lục, núi non liên miên trùng điệp, vươn thẳng lên mây. "
"Địa thế hiểm trở, kỳ thạch dị động khắp nơi, là vùng đất được giới mạo hiểm "
"ưa chuộng để tầm bảo."

#. normal_region.csv: 青峰山脉
msgid "NORMAL_REGION_107_NAME"
msgstr "Thanh Phong Sơn Mạch"

#. normal_region.csv: 位于大陆西北，雪峰皑皑，寒风刺骨。此地终...
msgid "NORMAL_REGION_108_DESC"
msgstr ""
"Nằm ở tây bắc đại lục, tuyết phong trắng xóa, hàn phong cắt da cắt thịt. "
"Quanh năm phủ tuyết, đường núi gập ghềnh hiểm trở, là thử thách tối thượng "
"đối với những kẻ leo núi."

#. normal_region.csv: 万丈雪峰
msgid "NORMAL_REGION_108_NAME"
msgstr "Vạn Trượng Tuyết Phong"

#. normal_region.csv: 位于大陆西部，芳草萋萋，一望无际。此地水...
msgid "NORMAL_REGION_109_DESC"
msgstr ""
"Nằm ở phía tây đại lục, cỏ xanh bát ngát trải dài tới tận chân trời. Thủy "
"thảo phong mỹ, đàn trâu dê thành bầy, là mục trường thiên nhiên của các bộ "
"tộc du mục."

#. normal_region.csv: 碧野千里
msgid "NORMAL_REGION_109_NAME"
msgstr "Bích Dã Thiên Lý"

#. normal_region.csv: 位于大陆中部，古树参天，绿意盎然。此地森...
msgid "NORMAL_REGION_110_DESC"
msgstr ""
"Nằm ở trung bộ đại lục, cổ thụ chọc trời, xanh biếc ngút mắt. Rừng già rộng "
"lớn, tài nguyên phong phú, là nơi hoạt động chủ yếu của tiều phu và thợ săn."

#. normal_region.csv: 青云林海
msgid "NORMAL_REGION_110_NAME"
msgstr "Thanh Vân Lâm Hải"

#. normal_region.csv: 位于大陆东北，烈焰冲天，岩浆奔流。此地火...
msgid "NORMAL_REGION_111_DESC"
msgstr ""
"Nằm ở đông bắc đại lục, liệt diễm xung thiên, dung nham chảy cuồn cuộn. Núi "
"lửa hoạt động mạnh, địa hỏa dồi dào, là nơi tuyệt hảo để rèn đúc, nhưng cũng "
"vô cùng hung hiểm."

#. normal_region.csv: 炎狱火山
msgid "NORMAL_REGION_111_NAME"
msgstr "Viêm Ngục Hỏa Sơn"

#. normal_region.csv: 位于大陆东部，土地肥沃，五谷丰登。此地土...
msgid "NORMAL_REGION_112_DESC"
msgstr ""
"Nằm ở phía đông đại lục, đất đai màu mỡ, ngũ cốc tốt tươi. Thổ nhưỡng sâu "
"dày, mưa thuận gió hòa, là bảo địa vàng son cho nông gia canh tác."

#. normal_region.csv: 沃土良田
msgid "NORMAL_REGION_112_NAME"
msgstr "Ốc Thổ Lương Điền"

#. normal_region.csv: 位于大陆正南，终年被五色瘴气笼罩，毒虫遍...
msgid "NORMAL_REGION_113_DESC"
msgstr ""
"Nằm ở chính nam đại lục, quanh năm bị ngũ sắc chướng khí bao phủ, độc trùng "
"khắp chốn. Phàm nhân bước vào sẽ hóa thành bạch cốt, chỉ những kẻ tu độc công "
"mới xem đây là động thiên phúc địa vô thượng."

#. normal_region.csv: 幽冥毒泽
msgid "NORMAL_REGION_113_NAME"
msgstr "U Minh Độc Trạch"

#. normal_region.csv: 位于大陆南部，苍茫群山连绵不绝，乃是妖族...
msgid "NORMAL_REGION_114_DESC"
msgstr ""
"Nằm ở phía nam đại lục, quần sơn bát ngát nối tiếp không dứt, là tổ địa của "
"Yêu tộc. Núi non hiểm trở, đường đi gian nan khó vượt."

#. normal_region.csv: 十万大山
msgid "NORMAL_REGION_114_NAME"
msgstr "Thập Vạn Đại Sơn"

#. normal_region.csv: 位于大陆中北，紫竹成林，灵气清冽。风过林...
msgid "NORMAL_REGION_115_DESC"
msgstr ""
"Nằm ở phía bắc trung bộ đại lục, tử trúc kết rừng, linh khí thanh liệt. Gió "
"thổi qua rừng vang lên như tiên nhạc; tĩnh tu nơi đây có thể gột rửa tâm ma "
"và cảm ngộ thiên địa chi đạo."

#. normal_region.csv: 紫竹幽境
msgid "NORMAL_REGION_115_NAME"
msgstr "Tử Trúc U Cảnh"

#. normal_region.csv: 位于大陆东北，寸草不生，冻土千尺。此地生...
msgid "NORMAL_REGION_116_DESC"
msgstr ""
"Nằm ở đông bắc đại lục, cỏ cây tuyệt tích, tầng băng đóng sâu ngàn thước. "
"Sinh cơ diệt tận, nhưng lại ẩn chứa cực hàn linh khí, thỉnh thoảng còn xuất "
"hiện vạn niên huyền băng."

#. normal_region.csv: 凛霜荒原
msgid "NORMAL_REGION_116_NAME"
msgstr "Lẫm Sương Hoang Nguyên"

#. normal_region.csv: 位于大陆西南，飞沙走石，狂风如刀。传说曾...
msgid "NORMAL_REGION_117_DESC"
msgstr ""
"Nằm ở tây nam đại lục, cát đá bay mù, cuồng phong như đao cắt mặt. Tương "
"truyền nơi đây từng có thiên tinh rơi xuống, đến nay vẫn còn lưu lại cuồng "
"bạo tinh lực cùng thiên ngoại vẫn thiết."

#. normal_region.csv: 碎星戈壁
msgid "NORMAL_REGION_117_NAME"
msgstr "Toái Tinh Qua Bích"

#. normal_region.csv: 位于极东海外，孤悬海外，云雾缭绕。岛上灵...
msgid "NORMAL_REGION_118_DESC"
msgstr ""
"Nằm ở ngoài khơi cực đông, cô độc treo mình nơi hải ngoại, mây mù lượn "
"quanh. Trên đảo linh tuyền phun trào, kỳ hoa dị thảo khắp chốn, mật độ linh "
"khí vượt xa lục địa, là nơi hải ngoại tán tu hằng mơ ước."

#. normal_region.csv: 蓬莱遗岛
msgid "NORMAL_REGION_118_NAME"
msgstr "Bồng Lai Di Đảo"
