msgid "CITY_REGION_301_DESC"
msgstr "繁华大城，人烟稠密，商贾云集，是交易天材地宝、寻找机缘的重要场所。"

msgid "CITY_REGION_301_NAME"
msgstr "青云城"

msgid "CITY_REGION_302_DESC"
msgstr "沙漠绿洲中的贸易小城，商队往来不绝，是修士补给和交流的重要据点。"

msgid "CITY_REGION_302_NAME"
msgstr "沙州城"

msgid "CITY_REGION_303_DESC"
msgstr "森林深处的修仙城镇，虽不及名都繁盛，却有众多修士在此栖居，是修炼和炼宝的理想之地。"

msgid "CITY_REGION_303_NAME"
msgstr "翠林城"

msgid "CITY_REGION_304_DESC"
msgstr "坐落于大河入海口的繁盛大城，百川归海，水运昌隆，是水系修士往来云集的宝地。"

msgid "CITY_REGION_304_NAME"
msgstr "沧澜城"

msgid "CITY_REGION_305_DESC"
msgstr "屹立于连绵群山之巅的山中小城，终年云雾缭绕，灵气纯净，是苦修之士感悟天道的绝佳场所。"

msgid "CITY_REGION_305_NAME"
msgstr "揽月城"
