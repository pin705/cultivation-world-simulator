# Action: Buy
msgid "buy_action_name"
msgstr "Buy"

msgid "buy_description"
msgstr "Buy items/equipment/elixirs in town"

msgid "buy_requirements"
msgstr "In town and have enough money"

# Action: HelpPeople
msgid "help_people_action_name"
msgstr "Help People"

msgid "help_people_description"
msgstr "Help people in town, consumes small amount of spirit stones"

msgid "help_people_requirements"
msgstr "Only in city areas, and have enough spirit stones"

