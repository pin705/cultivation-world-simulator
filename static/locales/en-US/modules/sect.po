msgid "Our sect has settled its priorities for the coming years; next we should guard our rules and foundations, recruit talent with care, reward and punish fairly, and expand our momentum through steady progress."
msgstr "Our sect has settled its priorities for the coming years; next we should guard our rules and foundations, recruit talent with care, reward and punish fairly, and expand our momentum through steady progress."

msgid "There is currently no celestial phenomenon."
msgstr "There is currently no celestial phenomenon."

msgid "A celestial phenomenon is present, but its description is missing."
msgstr "A celestial phenomenon is present, but its description is missing."

msgid "New disciples must abide by the sect rules."
msgstr "New disciples must abide by the sect rules."

msgid "{sect_name} has extended a recruitment invitation to you."
msgstr "{sect_name} has extended a recruitment invitation to you."

msgid "Sect overview: {sect_info}"
msgstr "Sect overview: {sect_info}"

msgid "Sect rules: {rule_desc}"
msgstr "Sect rules: {rule_desc}"

msgid "If you accept, you will become a disciple of this sect."
msgstr "If you accept, you will become a disciple of this sect."

msgid "Accept invitation"
msgstr "Accept invitation"

msgid "Join {sect_name} and become one of its disciples."
msgstr "Join {sect_name} and become one of its disciples."

msgid "Decline invitation"
msgstr "Decline invitation"

msgid "Remain an independent cultivator."
msgstr "Remain an independent cultivator."

