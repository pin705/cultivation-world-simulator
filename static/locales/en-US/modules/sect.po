msgstr "recruited {count} rogue cultivators"

msgid "declared war {count} times"
msgstr "declared war {count} times"

msgid "made peace {count} times"
msgstr "made peace {count} times"

msgid "expelled {count} members"
msgstr "expelled {count} members"

msgid "bestowed techniques {count} times"
msgstr "bestowed techniques {count} times"

msgid "granted spirit-stone support {count} times"
msgstr "granted spirit-stone support {count} times"

msgid "{sect_name} focused this round of sect decisions on consolidation and observation, with no major adjustments made."
msgstr "{sect_name} focused this round of sect decisions on consolidation and observation, with no major adjustments made."

msgid "{sect_name} this round of sect decisions:"
msgstr "{sect_name} this round of sect decisions:"

msgid "Every successful recruit immediately costs {recruit_cost} spirit stones and increases future yearly member upkeep."
msgstr "Every successful recruit immediately costs {recruit_cost} spirit stones and increases future yearly member upkeep."

msgid "Each support action always costs {support_amount} spirit stones."
msgstr "Each support action always costs {support_amount} spirit stones."

msgid "Granting techniques does not directly spend spirit stones, but it consumes sect inheritance resources; frequent rewards reduce the value and rarity of the sect's scripture collection."
msgstr "Granting techniques does not directly spend spirit stones, but it consumes sect inheritance resources; frequent rewards reduce the value and rarity of the sect's scripture collection."

