msgid "{sect_name} judged that {avatar_name} had gravely violated the sect rules and expelled them from the sect."
msgstr "{sect_name} judged that {avatar_name} had gravely violated the sect rules and expelled them from the sect."

msgid "{sect_name} bestowed the technique \"{technique_name}\" upon {avatar_name}."
msgstr "{sect_name} bestowed the technique \"{technique_name}\" upon {avatar_name}."

msgid "{sect_name} granted {amount} spirit stones to {avatar_name} in support of their cultivation."
msgstr "{sect_name} granted {amount} spirit stones to {avatar_name} in support of their cultivation."

