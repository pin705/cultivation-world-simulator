# Event Content
msgid ""
"In the auction for {item_name}, {winner_name} outbid {runner_up_name} with "
"{price} spirit stones and won the item."
msgstr ""
"In the auction for {item_name}, {winner_name} outbid {runner_up_name} with "
"{price} spirit stones and won the item."

msgid "Retreat Bonus"
msgstr "Retreat Insight"

# Additional Missing Translations
msgid "Unsupported item type: {item_type}"
msgstr "Unsupported item type: {item_type}"

msgid "retreat_action_name"
msgstr "Retreat"

msgid "retreat_death_append"
msgstr ""
" And exhausted the last trace of vitality during retreat, passed away."

msgid "retreat_desc"
msgstr ""
"Retreat, to breakthrough self. Extremely risky, only for those with great "
"perseverance."

msgid "retreat_fail"
msgstr ""
"Retreat failed! Vitality greatly damaged, lost {years} years of lifespan."

msgid "retreat_requirements"
msgstr "No restrictions; cooldown required"

msgid "retreat_start"
msgstr "{avatar} begins retreat, breakthrough time unknown."

msgid "retreat_story_prompt_fail"
msgstr ""
"This is about a failed retreat. Describe how the cultivator was troubled by "
"inner demons, self-doubt, and finally suffered backlash during the retreat. "
"No combat description needed."

msgid "retreat_story_prompt_success"
msgstr ""
"This is about a successful retreat. Describe how the cultivator overcame "
"loneliness, comprehended the Heavenly Dao, and finally broke through the "
"state of mind during the retreat. No combat description needed."

msgid "retreat_success"
msgstr ""
"Retreat successfully completed! Cultivation improved, understanding of "
"Heavenly Dao deepened."

msgid "{avatar_name} abandoned {item_name}."
msgstr "{avatar_name} abandoned {item_name}."

msgid ""
"{avatar_name} sold newly obtained {item_name}, gained {price} spirit stones."
msgstr ""
"{avatar_name} sold newly obtained {item_name}, gained {price} spirit stones."

msgid "game.sect_update_event"
msgstr "{sect_name} yearly settlement: income {income} spirit stones, salaries paid {upkeep} spirit stones, balance {net_change} spirit stones."

msgid "War weariness adjusted to {weariness_after} (active wars: {active_war_count}, yearly recovery: 3, previous: {weariness_before})."
msgstr "War weariness adjusted to {weariness_after} (active wars: {active_war_count}, yearly recovery: 3, previous: {weariness_before})."

msgid "game.sect_thinking_event"
msgstr "{sect_name} sect's thinking: {thinking}"

msgid "{winner} won the martial tournament championship and earned {amount} sect contribution for {sect_name}."
msgstr "{winner} won the martial tournament championship and earned {amount} sect contribution for {sect_name}."

msgid "{teacher_name} taught and guided others at the preaching conference, earning {amount} sect contribution for {sect_name}."
msgstr "{teacher_name} taught and guided others at the preaching conference, earning {amount} sect contribution for {sect_name}."

msgid "{winner_name} distinguished themselves in sect war and earned {amount} sect contribution for {sect_name}."
msgstr "{winner_name} distinguished themselves in sect war and earned {amount} sect contribution for {sect_name}."

msgid "Game automatically saved"
msgstr "Game automatically saved"

msgid "{avatar_name} made a name in the cultivation world and came to be known as \"{nickname}\"."
msgstr "{avatar_name} made a name in the cultivation world and came to be known as \"{nickname}\"."

msgid "{avatar} self-created technique '{item}'"
msgstr "{avatar} self-created technique \"{item}\"."

msgid "{avatar} self-created weapon '{item}'"
msgstr "{avatar} self-created weapon \"{item}\"."

msgid "{avatar} self-created auxiliary equipment '{item}'"
msgstr "{avatar} self-created auxiliary equipment \"{item}\"."

msgid "Equipped newly created {kind} '{item}', sold old equipment '{old_item}' for {refund} spirit stones"
msgstr "Equipped newly created {kind} \"{item}\", and sold old equipment \"{old_item}\" for {refund} spirit stones."

msgid "Equipped newly created {kind} '{item}'"
msgstr "Equipped newly created {kind} \"{item}\"."

