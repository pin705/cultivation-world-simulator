msgid ""
"\n"
"(Selecting {replace} will sell old {label})"
msgstr ""
"\n"
"（{replace} を選ぶと古い {label} は売却されます）"

# Sect Rank
msgid "patriarch"
msgstr "掌門"

msgid "phenomenon_change"
msgstr ""
"{old_name} は消え去り、新たな天地異象が現れた！ {new_name}: {new_desc}。"

msgid "world_creation_phenomenon"
msgstr "世界が生まれ、天地異象が降り立つ！ {name}: {desc}。"

msgid ""
"{avatar_name} deliberated and redefined their long-term objective: "
"{objective}"
msgstr ""
"{avatar_name} は熟考の末、長期目標を改めて定め直した: {objective}"

msgid "{avatar_name} determined their long-term objective: {objective}"
msgstr "{avatar_name} は長期目標を定めた: {objective}"

# Sect System - Sects
msgid "Base effect"
msgstr "基礎効果"

msgid "Sect random event"
msgstr "宗門ランダムイベント"

msgid "Temporary effect"
msgstr "一時効果"

msgid "{sect_name} (Alignment: {alignment}, Headquarters: {hq_name})"
msgstr "{sect_name}（属性: {alignment}、本拠地: {hq_name}）"

msgid ""
"{sect_name} (Alignment: {alignment}, Style: {style}, Headquarters: "
"{hq_name}){effect}"
msgstr ""
"{sect_name}（属性: {alignment}、気風: {style}、本拠地: {hq_name}）{effect}"

msgid ""
"{sect_name} (Orthodoxy: {orthodoxy}, Alignment: {alignment}, Headquarters: "
"{hq_name})"
msgstr ""
"{sect_name}（正道: {orthodoxy}、属性: {alignment}、本拠地: {hq_name}）"

msgid ""
"{sect_name} (Orthodoxy: {orthodoxy}, Alignment: {alignment}, Style: {style},"
" Headquarters: {hq_name}){effect}"
msgstr ""
"{sect_name}（正道: {orthodoxy}、属性: {alignment}、気風: {style}、本拠地: {hq_name}）{effect}"

msgid "Our sect has settled its priorities for the coming years; next we should guard our rules and foundations, recruit talent with care, reward and punish fairly, and expand our momentum through steady progress."
msgstr "我が宗は今後数年の方針を定めた。次は門規と基盤を守り、慎重に人材を募り、賞罰を公正に行い、着実な歩みで勢いを広げるべきである。"

msgid "There is currently no celestial phenomenon."
msgstr "現在、天地異象は存在しない。"

msgid "A celestial phenomenon is present, but its description is missing."
msgstr "天地異象は存在するが、その説明が欠けている。"

msgid "New disciples must abide by the sect rules."
msgstr "入門後は宗門の戒律を守らねばならない。"

msgid "{sect_name} has extended a recruitment invitation to you."
msgstr "{sect_name} があなたを招いている。"

msgid "Sect overview: {sect_info}"
msgstr "宗門概要: {sect_info}"

msgid "Sect rules: {rule_desc}"
msgstr "門規: {rule_desc}"

msgid "If you accept, you will become a disciple of this sect."
msgstr "受け入れれば、この宗門の弟子となる。"

msgid "Accept invitation"
msgstr "招きを受ける"

msgid "Join {sect_name} and become one of its disciples."
msgstr "{sect_name} に入り、門下の弟子となる。"

msgid "Decline invitation"
msgstr "招きを断る"

msgid "Remain an independent cultivator."
msgstr "散修のままでいる。"

msgid "{avatar_name} accepted {sect_name}'s invitation."
msgstr "{avatar_name} は {sect_name} の招きを受け入れた。"

msgid "{avatar_name} declined {sect_name}'s invitation."
msgstr "{avatar_name} は {sect_name} の招きを断った。"

msgid "{sect_name} declared war on {target_name}; from this point on, the two sects are at war."
msgstr "{sect_name} は {target_name} に宣戦し、両宗はここに戦火を交えることとなった。"

msgid "{sect_name} made peace with {target_name}, and the state of war between them came to an end."
msgstr "{sect_name} は {target_name} と講和し、両宗の戦は終わりを迎えた。"

msgid "{sect_name} spent {cost} spirit stones to recruit {avatar_name}; {avatar_name} officially became a disciple of the sect."
msgstr "{sect_name} は {cost} 霊石を投じて {avatar_name} を迎え入れ、{avatar_name} は正式に門下の弟子となった。"

msgid "{sect_name} judged that {avatar_name} had gravely violated the sect rules and expelled them from the sect."
msgstr "{sect_name} は {avatar_name} が門規に重大な違反を犯したと断じ、宗門から追放した。"

msgid "{sect_name} bestowed the technique \"{technique_name}\" upon {avatar_name}."
msgstr "{sect_name} は {avatar_name} に功法《{technique_name}》を授けた。"

msgid "{sect_name} granted {amount} spirit stones to {avatar_name} in support of their cultivation."
msgstr "{sect_name} は {avatar_name} に {amount} 霊石を与え、その修行を支えた。"

msgid "recruited {count} rogue cultivators"
msgstr "散修を {count} 名招いた"

msgid "declared war {count} times"
msgstr "{count} 度宣戦した"

msgid "made peace {count} times"
msgstr "{count} 度講和した"

msgid "expelled {count} members"
msgstr "門人を {count} 名追放した"

msgid "bestowed techniques {count} times"
msgstr "功法授与を {count} 度行った"

msgid "granted spirit-stone support {count} times"
msgstr "霊石支援を {count} 度行った"

msgid "{sect_name} focused this round of sect decisions on consolidation and observation, with no major adjustments made."
msgstr "{sect_name} は今期の宗門判断を整固と静観に充て、大きな変更は行わなかった。"

msgid "{sect_name} this round of sect decisions:"
msgstr "{sect_name} の今期の宗門判断:"

msgid "Every successful recruit immediately costs {recruit_cost} spirit stones and increases future yearly member upkeep."
msgstr "新たな門人を一人迎えるたびに、直ちに {recruit_cost} 霊石を消費し、今後の年間扶養負担も増していく。"

msgid "Each support action always costs {support_amount} spirit stones."
msgstr "支援を一度行うごとに、必ず {support_amount} 霊石を消費する。"

msgid "Granting techniques does not directly spend spirit stones, but it consumes sect inheritance resources; frequent rewards reduce the value and rarity of the sect's scripture collection."
msgstr "功法授与は直接霊石を減らさないが、宗門の伝承資源を消耗し、頻繁な下賜は蔵経の価値と希少性を損なう。"

msgid "[{month_stamp}] {content}"
msgstr "[{month_stamp}] {content}"
