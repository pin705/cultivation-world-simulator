msgid "(Choosing to replace will sell the old {label})"
msgstr "（交換を選ぶと古い {label} は売却される）"

msgid ", keep current '{old_name}'"
msgstr "、現在の「{old_name}」を維持"

msgid ", replace old {label} '{old_name}'"
msgstr "、古い {label}「{old_name}」を置き換える"

msgid ", sell old {label} '{old_name}'"
msgstr "、古い {label}「{old_name}」を売却"

# Simulator & Event Translations
msgid ""
"{avatar_name} passed by {region_name}, found it ownerless, and occupied it."
msgstr ""
"{avatar_name} は {region_name} を通りかかり、無主の地だと見て占拠した。"

msgid "{dynasty_title} has enthroned a new ruler, and {emperor_name} ascends as emperor."
msgstr "{dynasty_title} に新たな君主が立ち、{emperor_name} が皇帝として即位した。"

msgid "Emperor {emperor_name} of {dynasty_title} has passed away at the age of {age}."
msgstr "{dynasty_title} の皇帝 {emperor_name} は {age} 歳で崩御した。"

msgid "A new emperor ascends in {dynasty_title}: {emperor_name} inherits the throne."
msgstr "{dynasty_title} に新帝が即位した。{emperor_name} が帝位を継いだ。"

msgid "{avatar} neglected governance for too long, losing court reputation and falling from {old_rank} to {new_rank}."
msgstr "{avatar} は長く政務を怠り、声望を失って {old_rank} から {new_rank} へ降格した。"
