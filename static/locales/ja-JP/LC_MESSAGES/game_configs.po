#. animal.csv: 拥有上古血脉的巨型妖兽，皮毛如铁，行走间...
msgid "ANIMAL_10_DESC"
msgstr "上古の血脈を宿す巨躯の妖獣。毛皮は鉄のように硬く、一歩ごとに大地を震わせる。圧倒的な怪力を持つ。"

#. animal.csv: 撼地神牛
msgid "ANIMAL_10_NAME"
msgstr "撼地神牛"

#. animal.csv: 生存于冻土深处的冷血妖兽，身躯由半透明的...
msgid "ANIMAL_11_DESC"
msgstr "永久凍土の奥に棲む冷血の妖獣。半透明の骨と霜でできた体を持ち、音もなく獲物を凍らせる。"

#. animal.csv: 冰魄骨蛇
msgid "ANIMAL_11_NAME"
msgstr "氷魄骨蛇"

#. animal.csv: 天性机敏的灵性兔子，毛色雪白，蕴含微弱灵...
msgid "ANIMAL_1_DESC"
msgstr "生来聡敏な霊性の兎。雪のように白い毛並みに淡い霊気を宿し、穏やかで馴らしやすい。"

#. animal.csv: 灵兔
msgid "ANIMAL_1_NAME"
msgstr "霊兎"

#. animal.csv: 凶猛的魔性狼族，体型巨大，拥有强大的魔力...
msgid "ANIMAL_2_DESC"
msgstr "巨大な体躯と魔力、鋭い牙と爪を備えた凶暴な魔狼。獰猛で殺気に満ちている。"

#. animal.csv: 魔狼
msgid "ANIMAL_2_NAME"
msgstr "魔狼"

#. animal.csv: 栖息于平原地带的温和灵兽，通体青色，角如...
msgid "ANIMAL_3_DESC"
msgstr "平原に棲む温和な霊獣。全身は青く、玉のような角を持ち、霊気の変化を敏感に感じ取る。"

#. animal.csv: 青云鹿
msgid "ANIMAL_3_NAME"
msgstr "青雲鹿"

#. animal.csv: 南疆蛮荒中的敏捷猎手，身形如影，爪牙锋利...
msgid "ANIMAL_4_DESC"
msgstr "南疆の蛮荒に生きる俊敏な狩人。影のような身のこなしと鋭い爪牙を持ち、隠密の狩りを得意とする。"

#. animal.csv: 暗影豹
msgid "ANIMAL_4_NAME"
msgstr "暗影豹"

#. animal.csv: 无边碧海的古老灵兽，龟甲如碧玉，能操控海...
msgid "ANIMAL_5_DESC"
msgstr "果てなき碧海に棲む古き霊獣。碧玉のような甲羅をまとい、海水を操り、極めて長い寿命を持つ。"

#. animal.csv: 碧海龙龟
msgid "ANIMAL_5_NAME"
msgstr "碧海龍亀"

#. animal.csv: 青峰山脉的强壮守护者，皮毛坚如磐石，力大...
msgid "ANIMAL_6_DESC"
msgstr "青峰山脈を守る屈強な霊獣。毛皮は岩のように硬く、怪力を誇り、性質は質朴で実直。"

#. animal.csv: 石甲山熊
msgid "ANIMAL_6_NAME"
msgstr "石甲山熊"

#. animal.csv: 驰骋于碧野千里的神骏灵兽，四蹄生风，速度...
msgid "ANIMAL_7_DESC"
msgstr "千里の碧野を駆ける神駿の霊獣。四蹄に風を生じ、稲妻のような速度と流れるたてがみを持つ。"

#. animal.csv: 风速马
msgid "ANIMAL_7_NAME"
msgstr "風速馬"

#. animal.csv: 炎狱火山中的火系灵兽，鳞片赤红如火，能在...
msgid "ANIMAL_8_DESC"
msgstr "炎獄火山に棲む火属性の霊獣。鱗は燃えるように赤く、溶岩を泳ぎ、火炎を吐く。"

#. animal.csv: 熔岩蜥蜴
msgid "ANIMAL_8_NAME"
msgstr "熔岩蜥蜴"

#. animal.csv: 迷雾沼泽的剧毒生物，体色斑斓，能释放致命...
msgid "ANIMAL_9_DESC"
msgstr "霧の沼に潜む猛毒生物。体表はまだらに色づき、致命的な瘴毒を放ち、身を隠すことに長ける。"

#. animal.csv: 毒瘴蛙
msgid "ANIMAL_9_NAME"
msgstr "毒瘴蛙"

#. auxiliary.csv: 以灵木纤维编织，生机盎然，防御尚可....
msgid "AUXILIARY_2001_DESC"
msgstr "霊木の繊維を編み上げた防具。生気に満ち、防御性能も悪くない。"

#. auxiliary.csv: 木灵甲
msgid "AUXILIARY_2001_NAME"
msgstr "木霊甲"

#. auxiliary.csv: 生于火麒麟滴血之处，重伤必治，无伤增功....
msgid "AUXILIARY_2002_DESC"
msgstr "火麒麟が血を落とした極陽の地に生まれた霊果。傷を癒すだけでなく修為も高める。"

#. auxiliary.csv: 血菩提
msgid "AUXILIARY_2002_NAME"
msgstr "血菩提"

#. auxiliary.csv: 虽不及真品，闻一闻也能活三百六十岁....
msgid "AUXILIARY_2003_DESC"
msgstr "真物には及ばないが、香りを嗅ぐだけでも長寿をもたらすとされる。"

#. auxiliary.csv: 人参果(伪)
msgid "AUXILIARY_2003_NAME"
msgstr "人参果(偽)"

#. auxiliary.csv: 千帆城通用的高级商令。...
msgid "AUXILIARY_2004_DESC"
msgstr "千帆城で広く用いられる高級商令。"

#. auxiliary.csv: 万宝令
msgid "AUXILIARY_2004_NAME"
msgstr "万宝令"

#. auxiliary.csv: 提炼百斤凡铁才得一两，提升法器品质的基础...
msgid "AUXILIARY_2005_DESC"
msgstr "百斤の凡鉄からわずか一両しか得られない精華。法器の品質を高める基礎素材。"

#. auxiliary.csv: 铁精
msgid "AUXILIARY_2005_NAME"
msgstr "鉄精"

#. auxiliary.csv: 可勘破虚妄，直视本源，寻龙定穴....
msgid "AUXILIARY_2006_DESC"
msgstr "虚妄を見破り、本源を直視し、天地の機縁や大道の痕跡を探れる神眼。"

#. auxiliary.csv: 源天神眼
msgid "AUXILIARY_2006_NAME"
msgstr "源天神眼"

#. auxiliary.csv: 步履生云，身轻如燕，赶路必备....
msgid "AUXILIARY_2007_DESC"
msgstr "歩けば雲を生じ、身は燕のように軽くなる。移動の必需品。"

#. auxiliary.csv: 踏云靴
msgid "AUXILIARY_2007_NAME"
msgstr "踏雲靴"

#. auxiliary.csv: 佛门至宝，持之可灵台清明，悟性大增....
msgid "AUXILIARY_2008_DESC"
msgstr "仏門の至宝。携えれば霊台が清明となり、悟性が大きく増す。"

#. auxiliary.csv: 菩提子
msgid "AUXILIARY_2008_NAME"
msgstr "菩提子"

#. auxiliary.csv: 刀枪不入，水火不侵，贴身软甲....
msgid "AUXILIARY_2009_DESC"
msgstr "刀槍を通さず、水火を侵さぬ貼身の軟甲。"

#. auxiliary.csv: 金丝软甲
msgid "AUXILIARY_2009_NAME"
msgstr "金糸軟甲"

#. auxiliary.csv: 古墓派至宝，在此床上修炼，事半功倍，且无...
msgid "AUXILIARY_2010_DESC"
msgstr "極北の玄氷から作られた玉床。上で修行すれば心火を鎮め、効率も増す。"

#. auxiliary.csv: 寒玉床
msgid "AUXILIARY_2010_NAME"
msgstr "寒玉床"

#. auxiliary.csv: 千人千面，不仅掩盖容貌，更能掩盖气息....
msgid "AUXILIARY_2011_DESC"
msgstr "千人千面を成し、容貌だけでなく気息まで覆い隠す面具。"

#. auxiliary.csv: 无相面具
msgid "AUXILIARY_2011_NAME"
msgstr "無相面具"

#. auxiliary.csv: 飞行法器，速度极快，居家旅行杀人越货必备...
msgid "AUXILIARY_2051_DESC"
msgstr "高速で飛行できる法器。"

#. auxiliary.csv: 神风舟
msgid "AUXILIARY_2051_NAME"
msgstr "神風舟"

#. auxiliary.csv: 上古神器，拥有穿梭时空之力，此为仿品，仅...
msgid "AUXILIARY_2052_DESC"
msgstr "時空を穿つ力を持つ上古神器の仿品。本物には遠く及ばない。"

#. auxiliary.csv: 昆仑镜
msgid "AUXILIARY_2052_NAME"
msgstr "崑崙鏡"

#. auxiliary.csv: 夺天地之造化，聚日月之精华，催熟万物....
msgid "AUXILIARY_2053_DESC"
msgstr "天地造化を奪い、日月精華を集める宝瓶。瓶中の霊液は万物を催熟させる。"

#. auxiliary.csv: 掌天瓶
msgid "AUXILIARY_2053_NAME"
msgstr "掌天瓶"

#. auxiliary.csv: 龙凤和鸣，心意相通，双修进境一日千里....
msgid "AUXILIARY_2054_DESC"
msgstr "龍鳳和鳴し、心意を通わせ、双修の進境を大きく高める。"

#. auxiliary.csv: 龙凤呈祥戒
msgid "AUXILIARY_2054_NAME"
msgstr "龍鳳呈祥戒"

#. auxiliary.csv: 披上后身形尽隐，连神识也难以察觉....
msgid "AUXILIARY_2055_DESC"
msgstr "羽織れば姿を完全に隠し、神識ですら捉えにくくなる。"

#. auxiliary.csv: 隐形披风
msgid "AUXILIARY_2055_NAME"
msgstr "隠形披風"

#. auxiliary.csv: 套在妖兽颈上，任其凶焰滔天，也要乖乖听命...
msgid "AUXILIARY_2056_DESC"
msgstr "妖獣の頸に掛ければ、凶悪な獣でも従順に命を聞く。"

#. auxiliary.csv: 御兽环
msgid "AUXILIARY_2056_NAME"
msgstr "御獣環"

#. auxiliary.csv: 太虚幻境所化，万法不沾，防御力惊人....
msgid "AUXILIARY_2057_DESC"
msgstr "太虚幻境から化した甲。万法を寄せつけず、驚異的な防御力を持つ。"

#. auxiliary.csv: 太虚甲
msgid "AUXILIARY_2057_NAME"
msgstr "太虚甲"

#. auxiliary.csv: 仿太上老君炼丹炉，丹成九转，药效倍增....
msgid "AUXILIARY_2058_DESC"
msgstr "太上老君の丹炉を模した仿器。丹を九転させ、薬効を倍増させる。"

#. auxiliary.csv: 八卦炉
msgid "AUXILIARY_2058_NAME"
msgstr "八卦炉"

#. auxiliary.csv: 放入一文，取出万贯，财源滚滚....
msgid "AUXILIARY_2059_DESC"
msgstr "一文を入れれば万貫を引き寄せるとされる、財運の象徴。"

#. auxiliary.csv: 聚宝盆
msgid "AUXILIARY_2059_NAME"
msgstr "聚宝盆"

#. auxiliary.csv: 以天地为炉，造化为工，炼制万物....
msgid "AUXILIARY_2060_DESC"
msgstr "天地を炉とし、造化を工と見なして万物を煉ずる重宝。"

#. auxiliary.csv: 天地烘炉
msgid "AUXILIARY_2060_NAME"
msgstr "天地烘炉"

#. auxiliary.csv: 背负六道，剑出轮回，悟剑良伴....
msgid "AUXILIARY_2061_DESC"
msgstr "六道を背負い、剣が出れば輪回を帯びる。剣悟に優れた伴侶となる。"

#. auxiliary.csv: 六道剑匣
msgid "AUXILIARY_2061_NAME"
msgstr "六道剣匣"

#. auxiliary.csv: 受命于天，既寿永昌。皇威浩荡，震慑宵小....
msgid "AUXILIARY_2062_DESC"
msgstr "天命を受け、既寿永昌。皇威を広げ、小人を震え上がらせる重器。"

#. auxiliary.csv: 传国玉玺
msgid "AUXILIARY_2062_NAME"
msgstr "伝国玉璽"

#. auxiliary.csv: 可移动的灵气之源，随身携带的洞天福地....
msgid "AUXILIARY_2063_DESC"
msgstr "持ち運べる霊気の源であり、随身の洞天福地でもある。"

#. auxiliary.csv: 灵眼之泉
msgid "AUXILIARY_2063_NAME"
msgstr "霊眼之泉"

#. auxiliary.csv: 血海不枯，冥河不死。极度邪恶的掠夺法宝....
msgid "AUXILIARY_2064_DESC"
msgstr "血海は枯れず、冥河は死なず。極めて邪悪な掠奪法宝。"

#. auxiliary.csv: 万魂幡
msgid "AUXILIARY_2064_NAME"
msgstr "万魂幡"

#. auxiliary.csv: 木系至宝，不仅可炼制神丹，鼎中更自成一界...
msgid "AUXILIARY_2065_DESC"
msgstr "古の神木を削って作られた王鼎。神丹を煉ずるだけでなく、鼎内に一界を成して霊草を育てる。"

#. auxiliary.csv: 神木王鼎
msgid "AUXILIARY_2065_NAME"
msgstr "神木王鼎"

#. celestial_phenomenon.csv: 天地灵气井喷复苏，修为进境一日千里，万物...
msgid "CELESTIAL_PHENOMENON_10_DESC"
msgstr "天地霊気が噴き出すように蘇り、修為の進境は日進月歩となる。万物が競って伸び、全力で修行を進めるのに向く。"

#. celestial_phenomenon.csv: 灵气复苏
msgid "CELESTIAL_PHENOMENON_10_NAME"
msgstr "霊気復蘇"

#. celestial_phenomenon.csv: 灵气枯竭末法将至，修炼如逆水行舟，宜节约...
msgid "CELESTIAL_PHENOMENON_11_DESC"
msgstr "霊気は枯れ、末法の気配が迫る。修行は逆水を行くがごとく、資源を節し道心を守るべき時。"

#. celestial_phenomenon.csv: 灵气枯竭
msgid "CELESTIAL_PHENOMENON_11_NAME"
msgstr "霊気枯渇"

#. celestial_phenomenon.csv: 魔气滔天邪道大昌，魔修如鱼得水，正道修士...
msgid "CELESTIAL_PHENOMENON_12_DESC"
msgstr "魔気が天を覆い邪道が栄える。魔修は魚のように勢いづき、正道修士はその鋒を避けて蓄えるべきである。"

#. celestial_phenomenon.csv: 魔道兴盛
msgid "CELESTIAL_PHENOMENON_12_NAME"
msgstr "魔道興盛"

#. celestial_phenomenon.csv: 浩然正气镇压邪祟，正道修士如有神助，魔修...
msgid "CELESTIAL_PHENOMENON_13_DESC"
msgstr "浩然の正気が邪祟を鎮め、正道修士は神助を得たかのよう。魔修は潜んで不運を避けるしかない。"

#. celestial_phenomenon.csv: 正气浩然
msgid "CELESTIAL_PHENOMENON_13_NAME"
msgstr "正気浩然"

#. celestial_phenomenon.csv: 神兵有灵百兵齐鸣，兵器熟练度提升极快，宜...
msgid "CELESTIAL_PHENOMENON_14_DESC"
msgstr "神兵に霊が宿り、百兵が斉しく鳴る。兵器熟練は飛躍的に伸び、武芸と鋒を磨く好機。"

#. celestial_phenomenon.csv: 神兵出世
msgid "CELESTIAL_PHENOMENON_14_NAME"
msgstr "神兵出世"

#. celestial_phenomenon.csv: 阴阳交泰天地和合，彼此互补进境神速，最宜...
msgid "CELESTIAL_PHENOMENON_15_DESC"
msgstr "陰陽が和し天地が相合する。相補い合えば進境は神速となり、道侶を求め双修を楽しむに最適。"

#. celestial_phenomenon.csv: 阴阳交泰
msgid "CELESTIAL_PHENOMENON_15_NAME"
msgstr "陰陽交泰"

#. celestial_phenomenon.csv: 血光冲天杀意难抑，虽杀伐之力大增但机缘断...
msgid "CELESTIAL_PHENOMENON_16_DESC"
msgstr "血光が天を衝き、殺意は抑え難い。殺伐の力は増すが機縁は絶えやすく、殺により道を証す者向き。"

#. celestial_phenomenon.csv: 杀劫降临
msgid "CELESTIAL_PHENOMENON_16_NAME"
msgstr "殺劫降臨"

#. celestial_phenomenon.csv: 天下太平万物安宁，虽苦修进境缓慢但机缘频...
msgid "CELESTIAL_PHENOMENON_17_DESC"
msgstr "天下は太平で万物も安らか。苦修の進みは遅いが、機縁は頻繁に現れ、遊歴して奇遇を探すのに向く。"

#. celestial_phenomenon.csv: 太平盛世
msgid "CELESTIAL_PHENOMENON_17_NAME"
msgstr "太平盛世"

#. celestial_phenomenon.csv: 天命眷顾气运所钟，天选之人万事皆顺，常人...
msgid "CELESTIAL_PHENOMENON_18_DESC"
msgstr "天命に愛され気運が身に集まる。選ばれし者は万事順調で、常人は無理に競うべきではない。"

#. celestial_phenomenon.csv: 气运加身
msgid "CELESTIAL_PHENOMENON_18_NAME"
msgstr "気運加身"

#. celestial_phenomenon.csv: 血月高悬人心躁动，战力虽强但静修困难，宜...
msgid "CELESTIAL_PHENOMENON_19_DESC"
msgstr "血月が高く懸かり、人心は躁く。戦力は強まるが静修は難しく、戦いで資源を奪うのに向く。"

#. celestial_phenomenon.csv: 血月当空
msgid "CELESTIAL_PHENOMENON_19_NAME"
msgstr "血月当空"

#. celestial_phenomenon.csv: 天地灵气充沛，修士修行速度大增，修行欲望...
msgid "CELESTIAL_PHENOMENON_1_DESC"
msgstr "天地霊気が充ち、修士の修行速度が大きく上がり、修行への欲求も高まる。"

#. celestial_phenomenon.csv: 紫气东来
msgid "CELESTIAL_PHENOMENON_1_NAME"
msgstr "紫気東来"

#. celestial_phenomenon.csv: 天门大开大道显现，感悟修行皆如有神助，正...
msgid "CELESTIAL_PHENOMENON_20_DESC"
msgstr "天門が開き大道が顕れる。悟りも修行も神助のように進み、境界を衝いて昇仙を狙うべき時。"

#. celestial_phenomenon.csv: 飞升之门
msgid "CELESTIAL_PHENOMENON_20_NAME"
msgstr "飛昇之門"

#. celestial_phenomenon.csv: 天地法则清晰可触，瓶颈如纸一捅即破，万勿...
msgid "CELESTIAL_PHENOMENON_21_DESC"
msgstr "天地法則が明瞭に触れられ、瓶頸は紙のように破れやすい。天与の突破機を逃してはならない。"

#. celestial_phenomenon.csv: 法则显化
msgid "CELESTIAL_PHENOMENON_21_NAME"
msgstr "法則顕化"

#. celestial_phenomenon.csv: 时空错乱异象频生，险地亦藏无上机缘，宜富...
msgid "CELESTIAL_PHENOMENON_22_DESC"
msgstr "時空が乱れ、異象が頻発する。危地にも至上の機縁が潜み、危険に賭けて未知を探る好機。"

#. celestial_phenomenon.csv: 时空乱流
msgid "CELESTIAL_PHENOMENON_22_NAME"
msgstr "時空乱流"

#. celestial_phenomenon.csv: 金煞充盈天地肃杀，修士更大可能嗜血而相互...
msgid "CELESTIAL_PHENOMENON_2_DESC"
msgstr "金煞が天地に満ち、世界は粛殺に包まれる。修士は血に飢えやすく、互いに争いを起こしやすい。"

#. celestial_phenomenon.csv: 金煞之年
msgid "CELESTIAL_PHENOMENON_2_NAME"
msgstr "金煞之年"

#. celestial_phenomenon.csv: 木德滋养生机盎然，采集收获倍增且伤势恢复...
msgid "CELESTIAL_PHENOMENON_3_DESC"
msgstr "木徳が万物を潤し生機に満ちる。採集収穫は倍し、傷の回復も速く、天地奇珍を探すのに最適。"

#. celestial_phenomenon.csv: 木灵盛世
msgid "CELESTIAL_PHENOMENON_3_NAME"
