#. persona.csv: 沉迷玩乐，不思进取。...
msgid "PERSONA_1001_DESC"
msgstr "遊びに耽り、向上をあまり考えない。"

#. persona.csv: 贪玩
msgid "PERSONA_1001_NAME"
msgstr "貪玩"

#. persona.csv: 嗜书如命。...
msgid "PERSONA_1002_DESC"
msgstr "本を命のように愛している。"

#. persona.csv: 书痴
msgid "PERSONA_1002_NAME"
msgstr "書痴"

#. persona.csv: 宁可三日无食，不可一日无茶。...
msgid "PERSONA_1003_DESC"
msgstr "三日食がなくとも、一日たりとも茶なくして過ごせない。"

#. persona.csv: 茶痴
msgid "PERSONA_1003_NAME"
msgstr "茶痴"

#. persona.csv: 善抚琴。...
msgid "PERSONA_1004_DESC"
msgstr "琴をよく奏でる。"

#. persona.csv: 琴师
msgid "PERSONA_1004_NAME"
msgstr "琴師"

#. persona.csv: 读万卷书不如行万里路。...
msgid "PERSONA_1005_DESC"
msgstr "万巻の書を読むより、万里を行く方がよいと考える。"

#. persona.csv: 游历者
msgid "PERSONA_1005_NAME"
msgstr "遊歴者"

#. persona.csv: 善弈者长生。...
msgid "PERSONA_1006_DESC"
msgstr "囲碁や将棋に長ける者は長生すると信じている。"

#. persona.csv: 棋痴
msgid "PERSONA_1006_NAME"
msgstr "棋痴"

#. persona.csv: 你总是会珍惜自己的生命，不会轻易冒险。...
msgid "PERSONA_10_DESC"
msgstr "己の命を大切にし、軽々しく危険を冒さない。"

#. persona.csv: 惜命
msgid "PERSONA_10_NAME"
msgstr "惜命"

#. persona.csv: 你重视同伴与和谐，乐于助人。...
msgid "PERSONA_11_DESC"
msgstr "仲間と調和を重んじ、進んで人を助ける。"

#. persona.csv: 友爱
msgid "PERSONA_11_NAME"
msgstr "友愛"

#. persona.csv: 你绝不轻易放下仇怨，为了复仇愿意付出代价...
msgid "PERSONA_12_DESC"
msgstr "恨みを簡単には手放さず、復讐のためなら代価も時間も惜しまない。"

#. persona.csv: 复仇
msgid "PERSONA_12_NAME"
msgstr "復讐"

#. persona.csv: 你喜欢独处，避免与人深交。...
msgid "PERSONA_13_DESC"
msgstr "独りでいることを好み、人と深く交わるのを避ける。"

#. persona.csv: 孤僻
msgid "PERSONA_13_NAME"
msgstr "孤僻"

#. persona.csv: 你情感克制，对外界冷静疏离。...
msgid "PERSONA_14_DESC"
msgstr "感情を抑え、外界に対して冷静で距離を置いている。"

#. persona.csv: 淡漠
msgid "PERSONA_14_NAME"
msgstr "淡漠"

#. persona.csv: 你直面冲突，偏好以力量与对抗解决问题。...
msgid "PERSONA_15_DESC"
msgstr "衝突を正面から受け止め、力と対抗で問題を解決しようとする。"

#. persona.csv: 好斗
msgid "PERSONA_15_NAME"
msgstr "好闘"

#. persona.csv: 你行事冲动、少考虑后果，常凭直觉立刻行动...
msgid "PERSONA_16_DESC"
msgstr "衝動的に動き、結果をあまり考えない。"

#. persona.csv: 鲁莽
msgid "PERSONA_16_NAME"
msgstr "魯莽"

#. persona.csv: 你谨小慎微，容易畏惧风险。...
msgid "PERSONA_17_DESC"
msgstr "小心で慎重、危険を恐れやすい。"

#. persona.csv: 胆小
msgid "PERSONA_17_NAME"
msgstr "胆小"

#. persona.csv: 你行事强势，不讲道理，习惯以自己的利益为...
msgid "PERSONA_18_DESC"
msgstr "強引で理屈を通さず、自分の利益を第一に置きがち。"

#. persona.csv: 霸道
msgid "PERSONA_18_NAME"
msgstr "覇道"

#. persona.csv: 你将绝大多数时间用于修炼，厌恶享乐。...
msgid "PERSONA_19_DESC"
msgstr "大半の時間を修行に費やし、享楽を嫌う。"

#. persona.csv: 修行痴迷
msgid "PERSONA_19_NAME"
msgstr "修行痴迷"

#. persona.csv: 你总是会用逻辑来思考问题，做事会谋定而后...
msgid "PERSONA_1_DESC"
msgstr "常に論理で考え、物事は計画してから行う。"

#. persona.csv: 理性
msgid "PERSONA_1_NAME"
msgstr "理性"

#. persona.csv: 你更享受独处与自我思考，倾向回避不必要的...
msgid "PERSONA_20_DESC"
msgstr "独りと内省をより楽しみ、不必要な社交を避ける。"

#. persona.csv: 内向
msgid "PERSONA_20_NAME"
msgstr "内向"

#. persona.csv: 你乐于与人交流，主动结识伙伴。...
msgid "PERSONA_21_DESC"
msgstr "人と話すことを楽しみ、進んで仲間を作る。"

#. persona.csv: 外向
msgid "PERSONA_21_NAME"
msgstr "外向"

#. persona.csv: 你在对话中倾向以讽刺、嘲弄、挖苦的方式表...
msgid "PERSONA_22_DESC"
msgstr "会話では皮肉、嘲り、辛辣さを交えて表現しがち。"

#. persona.csv: 刻薄
msgid "PERSONA_22_NAME"
msgstr "刻薄"

#. persona.csv: 你待人友好、积极回应，倾向用鼓励与赞美拉...
msgid "PERSONA_23_DESC"
msgstr "人に親しみやすく、前向きに応じ、励ましや称賛で距離を縮める。"

#. persona.csv: 热情
msgid "PERSONA_23_NAME"
msgstr "熱情"

#. persona.csv: 你对邪恶深恶痛绝，对正义的理想抱有近乎偏...
msgid "PERSONA_24_DESC"
msgstr "邪悪を深く憎み、正義の理想をほとんど偏執的なほどに信じている。"

#. persona.csv: 极端正义
msgid "PERSONA_24_NAME"
msgstr "極端正義"

#. persona.csv: 你推崇权力与恐惧，为达目的不择手段。...
msgid "PERSONA_25_DESC"
msgstr "権力と恐怖を崇め、目的のためなら手段を選ばない。"

#. persona.csv: 极端邪恶
msgid "PERSONA_25_NAME"
msgstr "極端邪悪"

#. persona.csv: 你对待和他人结为道侣或者双修比较随意...
msgid "PERSONA_26_DESC"
msgstr "他者と道侶になったり双修したりすることに比較的気軽。"

#. persona.csv: 开放
msgid "PERSONA_26_NAME"
msgstr "奔放"

#. persona.csv: 你对待和他人结为道侣或者双修比较谨慎...
msgid "PERSONA_27_DESC"
msgstr "他者と道侶になったり双修したりすることに比較的慎重。"

#. persona.csv: 腼腆
msgid "PERSONA_27_NAME"
msgstr "内気"

#. persona.csv: 你对异性中外貌出众者格外友善。...
msgid "PERSONA_28_DESC"
msgstr "異性の中でも容姿が特に優れた者に対してひときわ親切になる。"

#. persona.csv: 舔狗
msgid "PERSONA_28_NAME"
msgstr "媚び気質"

#. persona.csv: 你对远超于你的人容易产生敌意。...
msgid "PERSONA_29_DESC"
msgstr "自分を大きく上回る者に敵意を抱きやすい。"

#. persona.csv: 嫉妒
msgid "PERSONA_29_NAME"
msgstr "嫉妬"

#. persona.csv: 目标飘忽不定，不会长期坚持一个目标。...
msgid "PERSONA_2_DESC"
msgstr "目標が定まりにくく、一つの目標を長く貫かない。"

#. persona.csv: 无常
msgid "PERSONA_2_NAME"
msgstr "無常"

#. persona.csv: 你来自现代社会，怀念现代社会的一切。...
msgid "PERSONA_30_DESC"
msgstr "現代社会から来た者で、あの時代のすべてを懐かしんでいる。"

#. persona.csv: 穿越者
msgid "PERSONA_30_NAME"
msgstr "転移者"

#. persona.csv: 天生气运加身，更易遇到奇遇。...
msgid "PERSONA_31_DESC"
msgstr "生まれながらに気運をまとい、奇遇に出会いやすい。"

#. persona.csv: 气运之子
msgid "PERSONA_31_NAME"
msgstr "気運の子"

#. persona.csv: 以剑入道，剑即是命。你认为剑道至上。...
msgid "PERSONA_32_DESC"
msgstr "剣によって入道し、剣こそ命だと信じている。剣道至上。"

#. persona.csv: 剑痴
msgid "PERSONA_32_NAME"
msgstr "剣痴"

#. persona.csv: 深藏不露，行事谨慎，善于算计。...
msgid "PERSONA_33_DESC"
msgstr "本心を深く隠し、慎重に振る舞い、計算にも長ける。"

#. persona.csv: 心机深沉
msgid "PERSONA_33_NAME"
msgstr "深謀"

#. persona.csv: 重承诺守信义，对认定的人绝不背叛。...
msgid "PERSONA_34_DESC"
msgstr "約束と信義を重んじ、認めた相手を決して裏切らない。"

#. persona.csv: 忠诚
msgid "PERSONA_34_NAME"
msgstr "忠誠"

#. persona.csv: 行事果决狠辣，不留后患，斩草必除根。...
msgid "PERSONA_35_DESC"
msgstr "決断は苛烈で容赦なく、後患を残さない。"

#. persona.csv: 狠辣
msgid "PERSONA_35_NAME"
msgstr "苛烈"

#. persona.csv: 经历过一世，对未来有模糊预知。...
msgid "PERSONA_36_DESC"
msgstr "一世を経験しており、未来に対して曖昧な予感を持つ。"

#. persona.csv: 重生者
msgid "PERSONA_36_NAME"
msgstr "転生者"

#. persona.csv: 对任何人都保持怀疑，不轻易信任。...
msgid "PERSONA_37_DESC"
msgstr "誰に対しても疑い深く、容易には信じない。"

#. persona.csv: 疑心重
msgid "PERSONA_37_NAME"
msgstr "疑心重"

#. persona.csv: 专注肉身淬炼，体魄强健，近战无敌。...
msgid "PERSONA_38_DESC"
msgstr "肉身の淬錬に専念し、体魄は強健、近接戦では無類。"

#. persona.csv: 体修
msgid "PERSONA_38_NAME"
msgstr "鍛体修士"

#. persona.csv: 精通丹道，对灵药敏感。...
msgid "PERSONA_39_DESC"
msgstr "丹道に精通し、霊薬に対する感覚が鋭い。"

#. persona.csv: 炼丹师
msgid "PERSONA_39_NAME"
msgstr "煉丹師"

#. persona.csv: 你总是会拖延，不想努力，更热衷于享受人生...
msgid "PERSONA_3_DESC"
msgstr "つい先延ばしにし、努力を嫌い、人生を楽しむ方へ流れやすい。"

#. persona.csv: 怠惰
msgid "PERSONA_3_NAME"
msgstr "怠惰"

#. persona.csv: 天生福运，逢凶化吉。...
msgid "PERSONA_40_DESC"
msgstr "生来福運に恵まれ、凶を吉へ転じやすい。"

#. persona.csv: 福缘深厚
msgid "PERSONA_40_NAME"
msgstr "福縁深厚"

#. persona.csv: 对剑道有着深厚的兴趣和独特的天赋。...
msgid "PERSONA_41_DESC"
msgstr "剣道に深い興味と独特の才を備えている。"

#. persona.csv: 剑修
msgid "PERSONA_41_NAME"
msgstr "剣修士"

#. persona.csv: 专精刀法，对刀道有着独特的理解。...
msgid "PERSONA_42_DESC"
msgstr "刀法を専ら修め、刀道への独自の理解を持つ。"

#. persona.csv: 刀修
msgid "PERSONA_42_NAME"
msgstr "刀修士"

#. persona.csv: 精通枪法，百兵之王在手。...
msgid "PERSONA_43_DESC"
msgstr "槍法に精通し、百兵の王を手にして戦う。"

#. persona.csv: 枪修
msgid "PERSONA_43_NAME"
msgstr "槍修士"

#. persona.csv: 棍棒在手，天下我有。...
msgid "PERSONA_44_DESC"
msgstr "棍棒を握れば天下我にありと信じる。"

#. persona.csv: 棍修
msgid "PERSONA_44_NAME"
msgstr "棍修士"

#. persona.csv: 精通音律之道，琴笛在手，可攻可守。...
msgid "PERSONA_45_DESC"
msgstr "音律の道に通じ、琴や笛で攻めも守りもこなす。"

#. persona.csv: 音律大师
msgid "PERSONA_45_NAME"
msgstr "音律大師"

#. persona.csv: 擅长使用暗器，出手诡秘莫测。...
msgid "PERSONA_46_DESC"
msgstr "暗器の扱いに長け、出手は奇詭で測りがたい。"

#. persona.csv: 暗器高手
msgid "PERSONA_46_NAME"
msgstr "暗器達人"

#. persona.csv: 精通扇法，举手投足间尽显风流。...
msgid "PERSONA_47_DESC"
msgstr "扇法に熟達し、挙手投足のすべてに風流が宿る。"

#. persona.csv: 扇修
msgid "PERSONA_47_NAME"
msgstr "扇修士"

#. persona.csv: 精通鞭法，软兵器在手，刚柔并济。...
msgid "PERSONA_48_DESC"
msgstr "鞭法に熟達し、柔兵器で剛柔を兼ね備える。"

#. persona.csv: 鞭修
msgid "PERSONA_48_NAME"
msgstr "鞭修士"

#. persona.csv: 以刀入道，刀即是命。你认为刀法至上。...
msgid "PERSONA_49_DESC"
msgstr "刀によって入道し、刀こそ命だと信じる。刀法至上。"

#. persona.csv: 刀痴
msgid "PERSONA_49_NAME"
msgstr "刀痴"

#. persona.csv: 你总是会冒险，喜欢刺激，总想放手一搏。...
msgid "PERSONA_4_DESC"
msgstr "危険を好み、刺激を愛し、いつでも一か八かを試みたがる。"

#. persona.csv: 冒险
msgid "PERSONA_4_NAME"
msgstr "冒険"

#. persona.csv: 以枪入道，枪即是命。你认为枪法至上。...
msgid "PERSONA_50_DESC"
msgstr "槍によって入道し、槍こそ命だと信じる。"

#. persona.csv: 枪痴
msgid "PERSONA_50_NAME"
msgstr "槍痴"

#. persona.csv: 以棍入道，棍即是命。棍法通神。...
msgid "PERSONA_51_DESC"
msgstr "棍によって入道し、棍こそ命。棍法は神に通ずる。"

#. persona.csv: 棍圣
msgid "PERSONA_51_NAME"
msgstr "棍聖"

#. persona.csv: 以扇入道，扇即是命。你认为扇法至上。...
msgid "PERSONA_52_DESC"
msgstr "扇によって入道し、扇こそ命だと信じる。扇法至上。"

#. persona.csv: 扇痴
msgid "PERSONA_52_NAME"
msgstr "扇痴"

#. persona.csv: 以鞭入道，鞭即是命。你认为鞭法至上。...
msgid "PERSONA_53_DESC"
msgstr "鞭によって入道し、鞭こそ命だと信じる。鞭法至上。"

#. persona.csv: 鞭痴
msgid "PERSONA_53_NAME"
msgstr "鞭痴"

#. persona.csv: 暗器之道登峰造极，杀人于无形。...
msgid "PERSONA_54_DESC"
msgstr "暗器の道は頂点に達し、形なきまま人を殺す。"

#. persona.csv: 刺客宗师
msgid "PERSONA_54_NAME"
msgstr "刺客宗師"

#. persona.csv: 你对美色有着强烈的渴求。...
msgid "PERSONA_55_DESC"
msgstr "美色に対して強い欲求を抱く。"

#. persona.csv: 好色
msgid "PERSONA_55_NAME"
msgstr "好色"

#. persona.csv: 你清心寡欲，对男女之事毫无兴趣。...
msgid "PERSONA_56_DESC"
msgstr "清心寡欲で、男女の情事にほとんど興味がない。"

#. persona.csv: 无欲
msgid "PERSONA_56_NAME"
msgstr "無欲"

#. persona.csv: 你对未知的世界充满好奇。...
msgid "PERSONA_57_DESC"
msgstr "未知の世界に強い好奇心を抱いている。"

#. persona.csv: 探险家
msgid "PERSONA_57_NAME"
msgstr "探険家"

#. persona.csv: 你极度排斥长途跋涉，更喜欢待在熟悉的区域...
msgid "PERSONA_58_DESC"
msgstr "長旅を極端に嫌い、慣れた区域に留まることを好む。"

#. persona.csv: 死宅
msgid "PERSONA_58_NAME"
msgstr "死宅"

#. persona.csv: 天生霉运缠身。...
msgid "PERSONA_59_DESC"
msgstr "生まれつき不運にまとわりつかれ、物事がうまく運びにくい。"

#. persona.csv: 扫把星
msgid "PERSONA_59_NAME"
msgstr "掃把星"

#. persona.csv: 你总是会随机应变，性子到哪里了就是哪里，...
msgid "PERSONA_5_DESC"
msgstr "状況に応じて気ままに振る舞い、決まった型に縛られない。"

#. persona.csv: 随性
msgid "PERSONA_5_NAME"
msgstr "随性"

#. persona.csv: 早年修行多舛；但若能坚持至金丹元婴，便可...
msgid "PERSONA_60_DESC"
msgstr "若い頃の修行は多難だが、金丹や元嬰まで至れれば大成する。"

#. persona.csv: 大器晚成
msgid "PERSONA_60_NAME"
msgstr "大器晩成"

#. persona.csv: 精通炼器之道，对材料敏锐。...
msgid "PERSONA_61_DESC"
msgstr "煉器の道に通じ、材料への感覚が鋭い。"

#. persona.csv: 炼器师
msgid "PERSONA_61_NAME"
msgstr "煉器師"

#. persona.csv: 你的情绪波动很大。...
msgid "PERSONA_62_DESC"
msgstr "感情の起伏が非常に大きい。"

#. persona.csv: 情绪化
msgid "PERSONA_62_NAME"
msgstr "感情的"

#. persona.csv: 擅长勘探挖掘，对矿脉有着独特的直觉。...
msgid "PERSONA_63_DESC"
msgstr "探鉱と採掘に長け、鉱脈への独特な勘を持つ。"

#. persona.csv: 矿工
msgid "PERSONA_63_NAME"
msgstr "鉱夫"

#. persona.csv: 你躲避风险和风头，尽力不担上任何风险。...
msgid "PERSONA_64_DESC"
msgstr "危険や注目を避け、可能な限りリスクを背負わないようにする。"

#. persona.csv: 苟
msgid "PERSONA_64_NAME"
msgstr "徹底保身"

#. persona.csv: 心胸狭窄，见不得别人比自己好。...
msgid "PERSONA_65_DESC"
msgstr "心が狭く、自分より恵まれた者を見るのが耐えられない。"

#. persona.csv: 妒忌
msgid "PERSONA_65_NAME"
msgstr "嫉妬深い"

#. persona.csv: 你重视家庭和血缘关系，以家族利益为重。...
msgid "PERSONA_66_DESC"
msgstr "家族と血縁を重んじ、家門の利益を第一に置く。"

#. persona.csv: 重亲情
msgid "PERSONA_66_NAME"
msgstr "家族重視"

#. persona.csv: 你重视朋友义气，为朋友可以两肋插刀。...
msgid "PERSONA_67_DESC"
msgstr "友情と義気を重んじ、友のためなら大きな代償も厭わない。"

#. persona.csv: 重义气
msgid "PERSONA_67_NAME"
msgstr "義気重視"

#. persona.csv: 你习惯独来独往，不轻易与人深交。...
msgid "PERSONA_68_DESC"
msgstr "独りでいることに慣れており、人と深い縁を結びにくい。"

#. persona.csv: 孤身一人
msgid "PERSONA_68_NAME"
msgstr "独り身"

#. persona.csv: 你对爱情专一，一旦认定便不会改变。...
msgid "PERSONA_69_DESC"
msgstr "愛情においては一途で、一度決めた相手を変えない。"

#. persona.csv: 专情
msgid "PERSONA_69_NAME"
msgstr "一途"

#. persona.csv: 你对灵石和财富有着强烈的渴望。...
msgid "PERSONA_6_DESC"
msgstr "霊石と財に強い執着を抱いている。"

#. persona.csv: 贪财
msgid "PERSONA_6_NAME"
msgstr "貪財"

#. persona.csv: 你容易动情，对美好的感情充满向往。...
msgid "PERSONA_70_DESC"
msgstr "情に動かされやすく、美しい感情関係に強く憧れる。"

#. persona.csv: 多情
msgid "PERSONA_70_NAME"
